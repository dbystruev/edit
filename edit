# ============================================================================
# Coordinate Parsing
# ============================================================================

parse_coordinate() {
    local coord="$1"
    local video_width="$2"
    local video_height="$3"
    
    # Check if percentage
    if [[ "$coord" =~ ^([0-9]+\.?[0-9]*)%$ ]]; then
        local pct="${BASH_REMATCH[1]}"
        echo "$pct"
        return 0
    fi
    
    # Check if pixel value
    if [[ "$coord" =~ ^[0-9]+\.?[0-9]*$ ]]; then
        echo "$coord"
        return 0
    fi
    
    error "Invalid coordinate format: $coord (use pixels or percentage)"
    return 1
}

parse_rect() {
    local rect_str="$1"
    local video_width="$2"
    local video_height="$3"
    
    # Split by space to get two corners
    local corners
    IFS=' ' read -ra corners <<< "$rect_str"
    
    if [[ ${#corners[@]} -ne 2 ]]; then
        error "Rectangle requires exactly two corners: X1,Y1 X2,Y2"
        return 1
    fi
    
    # Parse first corner
    IFS=',' read -r x1 y1 <<< "${corners[0]}"
    IFS=',' read -r x2 y2 <<< "${corners[1]}"
    
    # Convert percentages to pixels
    if [[ "$x1" =~ ^([0-9]+\.?[0-9]*)%$ ]]; then
        x1=$(echo "${BASH_REMATCH[1]} $video_width" | awk '{printf "%.0f", $1/100*$2}')
    fi
    if [[ "$y1" =~ ^([0-9]+\.?[0-9]*)%$ ]]; then
        y1=$(echo "${BASH_REMATCH[1]} $video_height" | awk '{printf "%.0f", $1/100*$2}')
    fi
    if [[ "$x2" =~ ^([0-9]+\.?[0-9]*)%$ ]]; then
        x2=$(echo "${BASH_REMATCH[1]} $video_width" | awk '{printf "%.0f", $1/100*$2}')
    fi
    if [[ "$y2" =~ ^([0-9]+\.?[0-9]*)%$ ]]; then
        y2=$(echo "${BASH_REMATCH[1]} $video_height" | awk '{printf "%.0f", $1/100*$2}')
    fi
    
    # Ensure x1,y1 is top-left and x2,y2 is bottom-right
    local min_x=$(( x1 < x2 ? x1 : x2 ))
    local min_y=$(( y1 < y2 ? y1 : y2 ))
    local max_x=$(( x1 > x2 ? x1 : x2 ))
    local max_y=$(( y1 > y2 ? y1 : y2 ))
    
    echo "$min_x $min_y $max_x $max_y"
}

# ============================================================================
# Time/Frame Parsing
# ============================================================================

parse_time() {
    local time_str="$1"
    
    # Check if frame number (prefixed with 'f')
    if [[ "$time_str" =~ ^f([0-9]+\.?[0-9]*)$ ]]; then
        echo "frame:${BASH_REMATCH[1]}"
        return 0
    fi
    
    # Otherwise treat as seconds
    if [[ "$time_str" =~ ^[0-9]+\.?[0-9]*$ ]]; then
        echo "seconds:$time_str"
        return 0
    fi
    
    error "Invalid time format: $time_str (use seconds or f followed by frame number)"
    return 1
}

time_to_seconds() {
    local time_str="$1"
    local fps="$2"
    
    if [[ "$time_str" =~ ^frame:([0-9]+\.?[0-9]*)$ ]]; then
        echo "${BASH_REMATCH[1]}" | awk -v fps="$fps" '{printf "%.6f", $1/fps}'
    elif [[ "$time_str" =~ ^seconds:([0-9]+\.?[0-9]*)$ ]]; then
        echo "${BASH_REMATCH[1]}"
    fi
}

# ============================================================================
# Video Info Helpers
# ============================================================================

get_video_info() {
    local input="$1"
    local field="$2"
    
    ffprobe -v quiet -select_streams v:0 \
        -show_entries "stream=$field" \
        -of csv=p=0 "$input" 2>/dev/null
}

get_video_width() {
    get_video_info "$1" "width"
}

get_video_height() {
    get_video_info "$1" "height"
}

get_video_fps() {
    local fps_str
    fps_str=$(get_video_info "$1" "r_frame_rate")
    
    # Convert fraction to decimal
    if [[ "$fps_str" =~ ^([0-9]+)/([0-9]+)$ ]]; then
        echo "${BASH_REMATCH[1]} ${BASH_REMATCH[2]}" | awk '{printf "%.6f", $1/$2}'
    else
        echo "$fps_str"
    fi
}

get_duration() {
    ffprobe -v quiet -show_entries format=duration \
        -of csv=p=0 "$1" 2>/dev/null
}

get_frame_count() {
    ffprobe -v quiet -select_streams v:0 \
        -show_entries stream=nb_read_frames \
        -of csv=p=0 "$1" 2>/dev/null
}

# ============================================================================
# Opacity Parsing
# ============================================================================

parse_opacity() {
    local opacity_str="$1"
    
    # Handle percentage
    if [[ "$opacity_str" =~ ^([0-9]+\.?[0-9]*)%$ ]]; then
        echo "${BASH_REMATCH[1]}" | awk '{printf "%.2f", $1/100}'
        return 0
    fi
    
    # Handle decimal 0.0-1.0
    if [[ "$opacity_str" =~ ^[0-9]+\.?[0-9]*$ ]]; then
        echo "$opacity_str"
        return 0
    fi
    
    error "Invalid opacity format: $opacity_str (use 0.0-1.0 or 0%-100%)"
    return 1
}

# ============================================================================
# Fade Duration Calculation
# ============================================================================

get_fade_duration() {
    local mode="$1"
    
    case "$mode" in
        none) echo "0" ;;
        quick) echo "0.5" ;;
        slow) echo "1.5" ;;
        *) error "Unknown fade mode: $mode"; return 1 ;;
    esac
}

# ============================================================================
# insert-picture Command
# ============================================================================

cmd_insert_picture() {
    local input=""
    local output=""
    local picture=""
    local at="seconds:0"
    local duration="seconds:3"
    local appear="quick"
    local disappear="quick"
    local rect=""
    local mode="aspect-fit"
    local opacity="1.0"
    local transparent_bg="yes"

    # Check for help first
    for arg in "$@"; do
        if [[ "$arg" == "-h" || "$arg" == "--help" ]]; then
            show_insert_picture_help
            exit 0
        fi
    done
    
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --at)
                at=$(parse_time "$2") || exit 1
                shift 2
                ;;
            --duration)
                duration=$(parse_time "$2") || exit 1
                shift 2
                ;;
            --appear)
                appear="$2"
                shift 2
                ;;
            --disappear)
                disappear="$2"
                shift 2
                ;;
            --rect)
                rect="$2 $3"
                shift 3
                ;;
            --mode)
                mode="$2"
                shift 2
                ;;
            --opacity)
                opacity=$(parse_opacity "$2") || exit 1
                shift 2
                ;;
            --transparent-bg)
                transparent_bg="$2"
                shift 2
                ;;
            -*)
                error "Unknown option: $1"
                show_insert_picture_help
                exit 1
                ;;
            *)
                if [[ -z "$input" ]]; then
                    input="$1"
                elif [[ -z "$output" ]]; then
                    output="$1"
                elif [[ -z "$picture" ]]; then
                    picture="$1"
                else
                    error "Unexpected argument: $1"
                    exit 1
                fi
                shift
                ;;
        esac
    done
    
    # Validate required arguments
    local missing=()
    [[ -z "$input" ]] && missing+=("INPUT video file")
    [[ -z "$output" ]] && missing+=("OUTPUT video file")
    [[ -z "$picture" ]] && missing+=("PICTURE file")
    [[ -z "$rect" ]] && missing+=("--rect X1,Y1 X2,Y2")
    
    if [[ ${#missing[@]} -gt 0 ]]; then
        error "Missing required arguments:"
        for m in "${missing[@]}"; do
            echo "  - $m"
        done
        echo ""
        show_insert_picture_help
        exit 1
    fi
    
    # Validate input files exist
    [[ ! -f "$input" ]] && error "Input video not found: $input" && exit 1
    [[ ! -f "$picture" ]] && error "Picture file not found: $picture" && exit 1
    
    # Get video dimensions
    local width height
    width=$(get_video_width "$input") || { error "Failed to read video info"; exit 1; }
    height=$(get_video_height "$input") || { error "Failed to read video info"; exit 1; }
    
    if [[ -z "$width" || -z "$height" ]]; then
        error "Could not determine video dimensions"
        exit 1
    fi
    
    info "Video: ${width}x${height}"
    
    # Parse rectangle coordinates
    local coords
    coords=$(parse_rect "$rect" "$width" "$height") || exit 1
    
    local x1 y1 x2 y2
    read -r x1 y1 x2 y2 <<< "$coords"
    
    local rect_w=$(( x2 - x1 ))
    local rect_h=$(( y2 - y1 ))
    
    info "Picture area: ${x1},${y1} to ${x2},${y2} (${rect_w}x${rect_h})"
    
    # Get video fps
    local fps
    fps=$(get_video_fps "$input")
    
    # Convert time values to seconds
    local start_seconds duration_seconds
    start_seconds=$(time_to_seconds "$at" "$fps")
    duration_seconds=$(time_to_seconds "$duration" "$fps")
    
    # Calculate fade durations
    local fade_in_duration fade_out_duration
    fade_in_duration=$(get_fade_duration "$appear")
    fade_out_duration=$(get_fade_duration "$disappear")
    
    info "Start: ${start_seconds}s, Duration: ${duration_seconds}s"
    info "Fade in: ${fade_in_duration}s, Fade out: ${fade_out_duration}s"
    
    # Build ffmpeg filter complex
    local filters=""
    local overlay_opts=""
    
    # Scale picture to fit rectangle
    case "$mode" in
        aspect-fit)
            filters="[1:v]scale=${rect_w}:${rect_h}:force_original_aspect_ratio=decrease,pad=${rect_w}:${rect_h}:(ow-iw)/2:(oh-ih)/2:color=black@0[ovr];"
            overlay_opts="overlay=${x1}:${y1}"
            ;;
        aspect-fill)
            filters="[1:v]scale=${rect_w}:${rect_h}:force_original_aspect_ratio=increase,crop=${rect_w}:${rect_h}[ovr];"
            overlay_opts="overlay=${x1}:${y1}"
            ;;
        scale)
            filters="[1:v]scale=${rect_w}:${rect_h}[ovr];"
            overlay_opts="overlay=${x1}:${y1}"
            ;;
        *)
            error "Unknown mode: $mode (use aspect-fit, aspect-fill, or scale)"
            exit 1
            ;;
    esac
    
    # Add fade effects
    local end_seconds
    end_seconds=$(echo "$start_seconds $duration_seconds" | awk '{printf "%.6f", $1 + $2}')
    
    if [[ "$fade_in_duration" != "0" ]]; then
        filters+="[ovr]fade=t=in:st=0:d=${fade_in_duration}[ovr];"
    fi
    
    if [[ "$fade_out_duration" != "0" ]]; then
        local fade_out_start
        fade_out_start=$(echo "$duration_seconds $fade_out_duration" | awk '{printf "%.6f", $1 - $2}')
        if [[ "$fade_in_duration" != "0" ]]; then
            filters="${filters%[ovr];}[ovr]fade=t=out:st=${fade_out_start}:d=${fade_out_duration}[ovr];"
        else
            filters+="[ovr]fade=t=out:st=${fade_out_start}:d=${fade_out_duration}[ovr];"
        fi
    fi
    
    # Handle transparency for PNG/GIF
    if [[ "$transparent_bg" == "yes" ]]; then
        if [[ "$picture" =~ \.(png|gif)$ ]]; then
            overlay_opts+=",format=rgba"
        fi
    fi
    
    # Apply opacity
    if [[ "$opacity" != "1.0" ]]; then
        if [[ "$filters" == *"[ovr];"* ]]; then
            filters="${filters%[ovr];}[ovr]colorchannelmixer=aa=${opacity}[ovr];"
        else
            filters+="[1:v]colorchannelmixer=aa=${opacity}[ovr];"
        fi
    fi
    
    # Final overlay filter
    filters+="[0:v][ovr]${overlay_opts}:enable='between(t,${start_seconds},${end_seconds})'[out]"
    
    # Execute ffmpeg
    info "Processing..."
    
    local ffmpeg_cmd=(
        ffmpeg -y
        -i "$input"
        -i "$picture"
        -filter_complex "$filters"
        -map "[out]"
        -map "0:a?"
        -c:a copy
        "$output"
    )
    
    if [[ "$AUTO_YES" == "true" ]]; then
        "${ffmpeg_cmd[@]}" 2>&1 | tail -5
    else
        "${ffmpeg_cmd[@]}"
    fi
    
    if [[ $? -eq 0 ]]; then
        success "Created: $output"
    else
        error "Failed to process video"
        exit 1
    fi
}


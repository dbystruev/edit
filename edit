# Display stats for a single file
display_stat() {
    local input="$1"
    local json_output="$2"
    local short_output="$3"
    
    [[ ! -f "$input" ]] && error "File not found: $input" && return 1
    
    # Get file size
    local file_size
    if [[ "$(uname)" == "Darwin" ]]; then
        file_size=$(stat -f%z "$input" 2>/dev/null || echo "unknown")
    else
        file_size=$(stat -c%s "$input" 2>/dev/null || echo "unknown")
    fi
    
    # Format file size
    local size_human
    if [[ "$file_size" != "unknown" ]]; then
        size_human=$(numfmt --to=iec-i --suffix=B "$file_size" 2>/dev/null || echo "${file_size} bytes")
    else
        size_human="unknown"
    fi
    
    if [[ "$json_output" == "true" ]]; then
        local width height fps duration codec format_name pixel_format bitrate
        width=$(get_video_width "$input" 2>/dev/null || echo "N/A")
        height=$(get_video_height "$input" 2>/dev/null || echo "N/A")
        fps=$(get_video_fps "$input" 2>/dev/null || echo "N/A")
        duration=$(get_duration "$input" 2>/dev/null || echo "N/A")
        codec=$(ffprobe -v quiet -select_streams v:0 -show_entries stream=codec_name -of csv=p=0 "$input" 2>/dev/null | tr -d '"' || echo "N/A")
        format_name=$(ffprobe -v quiet -show_entries format=format_name -of csv=p=0 "$input" 2>/dev/null | tr -d '"' || echo "N/A")
        pixel_format=$(ffprobe -v quiet -select_streams v:0 -show_entries stream=pix_fmt -of csv=p=0 "$input" 2>/dev/null | tr -d '"' || echo "N/A")
        bitrate=$(ffprobe -v quiet -show_entries format=bit_rate -of csv=p=0 "$input" 2>/dev/null || echo "N/A")
        
        cat << EOF
{
  "file": "$input",
  "size": "$file_size",
  "size_human": "$size_human",
  "format": "$format_name",
  "codec": "$codec",
  "width": "$width",
  "height": "$height",
  "fps": "$fps",
  "duration": "$duration",
  "pixel_format": "$pixel_format",
  "bitrate": "$bitrate"
}
EOF
    else
        echo ""
        echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "${BLUE} File Statistics${NC}"
        echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e " ${GREEN}File:${NC}         $input"
        echo -e " ${GREEN}Size:${NC}         $size_human ($file_size bytes)"
        
        local format_name
        format_name=$(ffprobe -v quiet -show_entries format=format_name -of csv=p=0 "$input" 2>/dev/null | tr -d '"' || echo "N/A")
        echo -e " ${GREEN}Format:${NC}       $format_name"
        
        local codec width height fps duration pixel_format bitrate frames
        codec=$(ffprobe -v quiet -select_streams v:0 -show_entries stream=codec_name -of csv=p=0 "$input" 2>/dev/null || echo "N/A")
        width=$(get_video_width "$input" 2>/dev/null || echo "N/A")
        height=$(get_video_height "$input" 2>/dev/null || echo "N/A")
        fps=$(get_video_fps "$input" 2>/dev/null || echo "N/A")
        duration=$(get_duration "$input" 2>/dev/null || echo "N/A")
        pixel_format=$(ffprobe -v quiet -select_streams v:0 -show_entries stream=pix_fmt -of csv=p=0 "$input" 2>/dev/null || echo "N/A")
        bitrate=$(ffprobe -v quiet -show_entries format=bit_rate -of csv=p=0 "$input" 2>/dev/null || echo "N/A")
        frames=$(ffprobe -v quiet -select_streams v:0 -show_entries stream=nb_frames -of csv=p=0 "$input" 2>/dev/null || echo "N/A")
        
        if [[ "$codec" != "N/A" ]]; then
            echo -e " ${GREEN}Video Codec:${NC}  $codec"
            echo -e " ${GREEN}Resolution:${NC}  ${width} × ${height}"
            echo -e " ${GREEN}Frame Rate:${NC}  $fps fps"
            echo -e " ${GREEN}Pixel Fmt:${NC}   $pixel_format"
        fi
        
        if [[ "$duration" != "N/A" ]]; then
            local hours minutes seconds_val
            hours=$(echo "$duration" | awk '{printf "%02d", int($1/3600)}')
            minutes=$(echo "$duration" | awk '{printf "%02d", int($1/60)%60}')
            seconds_val=$(echo "$duration" | awk '{printf "%06.3f", $1%60}')
            echo -e " ${GREEN}Duration:${NC}     ${hours}:${minutes}:${seconds_val} ($duration s)"
        fi
        
        if [[ "$frames" != "N/A" ]]; then
            echo -e " ${GREEN}Frames:${NC}       $frames"
        fi
        
        if [[ "$bitrate" != "N/A" && "$bitrate" != "N/A" ]]; then
            local bitrate_kbps
            bitrate_kbps=$(echo "$bitrate" | awk '{printf "%.0f", $1/1000}')
            echo -e " ${GREEN}Bitrate:${NC}      ${bitrate_kbps} kbps"
        fi
        
        local audio_codec audio_sample_rate audio_channels
        audio_codec=$(ffprobe -v quiet -select_streams a:0 -show_entries stream=codec_name -of csv=p=0 "$input" 2>/dev/null || echo "")
        
        if [[ -n "$audio_codec" && "$audio_codec" != "N/A" ]]; then
            audio_sample_rate=$(ffprobe -v quiet -select_streams a:0 -show_entries stream=sample_rate -of csv=p=0 "$input" 2>/dev/null || echo "N/A")
            audio_channels=$(ffprobe -v quiet -select_streams a:0 -show_entries stream=channels -of csv=p=0 "$input" 2>/dev/null || echo "N/A")
            
            echo -e " ${GREEN}Audio Codec:${NC}  $audio_codec"
            echo -e " ${GREEN}Sample Rate:${NC} ${audio_sample_rate} Hz"
            echo -e " ${GREEN}Channels:${NC}    $audio_channels"
        fi
        
        echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo ""
    fi
}

cmd_stat() {
    local files=()
    local json_output=false
    local short_output=false

    # Check for help first
    for arg in "$@"; do
        if [[ "$arg" == "-h" || "$arg" == "--help" ]]; then
            show_stat_help
            exit 0
        fi
    done
    
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json)
                json_output=true
                shift
                ;;
            --short)
                short_output=true
                shift
                ;;
            -*)
                error "Unknown option: $1"
                show_stat_help
                exit 1
                ;;
            *)
                files+=("$1")
                shift
                ;;
        esac
    done
    
    # Validate input
    if [[ ${#files[@]} -eq 0 ]]; then
        error "Missing required argument: FILE(s)"
        echo ""
        show_stat_help
        exit 1
    fi
    
    # Process each file
    local has_error=false
    for file in "${files[@]}"; do
        if [[ ! -f "$file" ]]; then
            error "File not found: $file"
            has_error=true
            continue
        fi
        display_stat "$file" "$json_output" "$short_output" || has_error=true
    done
    
    if [[ "$has_error" == "true" ]]; then
        exit 1
    fi
}

# ============================================================================
# crop Command - Extract portion of video
# ============================================================================

show_crop_help() {
    cat << 'EOF'
edit crop - Extract a portion of video by time

USAGE:
    edit crop INPUT OUTPUT [OPTIONS]

ARGUMENTS:
    INPUT           Input video file
    OUTPUT          Output video file

OPTIONS:
    --from TIME     Start time. Default: beginning
    --to TIME       End time. Default: end
    -v, --verbose   Show verbose output

TIME FORMATS:
    10          seconds
    10.5        seconds with decimal
    3:45        minutes:seconds
    2:03:45     hours:minutes:seconds

EXAMPLES:
    # Extract from 10s to 30s
    edit crop input.mp4 output.mp4 --from 10 --to 30

    # Extract from 1m30s to 3m45s
    edit crop input.mp4 output.mp4 --from 1:30 --to 3:45

    # Extract from start to 15s
    edit crop input.mp4 output.mp4 --to 15
EOF
}

cmd_crop() {
    local input=""
    local output=""
    local from_time=""
    local to_time=""

    for arg in "$@"; do
        if [[ "$arg" == "-h" || "$arg" == "--help" ]]; then
            show_crop_help
            exit 0
        fi
    done

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -v|--verbose) VERBOSE=true; shift ;;
            --from) from_time="$2"; shift 2 ;;
            --to) to_time="$2"; shift 2 ;;
            -*) error "Unknown option: $1"; show_crop_help; exit 1 ;;
            *)
                if [[ -z "$input" ]]; then input="$1"
                elif [[ -z "$output" ]]; then output="$1"
                else error "Unexpected argument: $1"; exit 1
                fi
                shift
                ;;
        esac
    done

    [[ -z "$input" ]] && error "Missing INPUT" && show_crop_help && exit 1
    [[ -z "$output" ]] && error "Missing OUTPUT" && show_crop_help && exit 1
    [[ ! -f "$input" ]] && error "File not found: $input" && exit 1

    local loglevel="warning"
    [[ "$VERBOSE" == "true" ]] && loglevel="info"

    local ffmpeg_cmd=(ffmpeg -y -loglevel "$loglevel")
    
    [[ -n "$from_time" ]] && ffmpeg_cmd+=(-ss "$from_time")
    ffmpeg_cmd+=(-i "$input")
    [[ -n "$to_time" ]] && ffmpeg_cmd+=(-to "$to_time")
    
    ffmpeg_cmd+=(-c copy -stats "$output")

    [[ "$VERBOSE" == "true" ]] && info "Command: ${ffmpeg_cmd[*]}"
    
    "${ffmpeg_cmd[@]}"
    [[ $? -eq 0 ]] && success "Created: $output" || error "Failed"
}

# ============================================================================
# cut Command - Remove portion of video
# ============================================================================

show_cut_help() {
    cat << 'EOF'
edit cut - Remove a portion of video by time

USAGE:
    edit cut INPUT OUTPUT [OPTIONS]

ARGUMENTS:
    INPUT           Input video file
    OUTPUT          Output video file

OPTIONS:
    --from TIME     Start of section to remove
    --to TIME       End of section to remove
    -v, --verbose   Show verbose output

TIME FORMATS:
    10          seconds
    10.5        seconds with decimal
    3:45        minutes:seconds
    2:03:45     hours:minutes:seconds

EXAMPLES:
    # Remove section from 15s to 25s
    edit cut input.mp4 output.mp4 --from 15 --to 25

    # Remove from 1m30s to 2m15s
    edit cut input.mp4 output.mp4 --from 1:30 --to 2:15

    # Remove from start to 10s
    edit cut input.mp4 output.mp4 --to 10
EOF
}

cmd_cut() {
    local input=""
    local output=""
    local from_time=""
    local to_time=""

    for arg in "$@"; do
        if [[ "$arg" == "-h" || "$arg" == "--help" ]]; then
            show_cut_help
            exit 0
        fi
    done

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -v|--verbose) VERBOSE=true; shift ;;
            --from) from_time="$2"; shift 2 ;;
            --to) to_time="$2"; shift 2 ;;
            -*) error "Unknown option: $1"; show_cut_help; exit 1 ;;
            *)
                if [[ -z "$input" ]]; then input="$1"
                elif [[ -z "$output" ]]; then output="$1"
                else error "Unexpected argument: $1"; exit 1
                fi
                shift
                ;;
        esac
    done

    [[ -z "$input" ]] && error "Missing INPUT" && show_cut_help && exit 1
    [[ -z "$output" ]] && error "Missing OUTPUT" && show_cut_help && exit 1
    [[ ! -f "$input" ]] && error "File not found: $input" && exit 1
    [[ -z "$from_time" && -z "$to_time" ]] && error "Specify --from and/or --to" && exit 1

    local loglevel="warning"
    [[ "$VERBOSE" == "true" ]] && loglevel="info"

    # Get duration
    local duration
    duration=$(get_duration "$input")

    local filter=""
    if [[ -n "$from_time" && -n "$to_time" ]]; then
        # Cut middle section: keep 0-from and to-end
        filter="[0:v]trim=start=0:end=${from_time},setpts=PTS-STARTPTS[v1];"
        filter+="[0:v]trim=start=${to_time},setpts=PTS-STARTPTS[v2];"
        filter+="[v1][v2]concat=n=2:v=1:a=0[vout];"
        filter+="[0:a]atrim=start=0:end=${from_time}[a1];"
        filter+="[0:a]atrim=start=${to_time}[a2];"
        filter+="[a1][a2]concat=n=2:v=0:a=1[aout]"
    elif [[ -n "$to_time" ]]; then
        # Cut from start to to_time
        filter="[0:v]trim=start=${to_time},setpts=PTS-STARTPTS[vout];"
        filter+="[0:a]atrim=start=${to_time}[aout]"
    elif [[ -n "$from_time" ]]; then
        # Cut from from_time to end
        filter="[0:v]trim=start=0:end=${from_time},setpts=PTS-STARTPTS[vout];"
        filter+="[0:a]atrim=start=0:end=${from_time}[aout]"
    fi

    local ffmpeg_cmd=(
        ffmpeg -y -loglevel "$loglevel"
        -i "$input"
        -filter_complex "$filter"
        -map "[vout]" -map "[aout]"
        -stats "$output"
    )

    [[ "$VERBOSE" == "true" ]] && info "Filter: $filter"
    
    "${ffmpeg_cmd[@]}"
    [[ $? -eq 0 ]] && success "Created: $output" || error "Failed"
}

# ============================================================================
# insert Command - Insert video at timestamp
# ============================================================================

show_insert_help() {
    cat << 'EOF'
edit insert - Insert another video at a timestamp

USAGE:
    edit insert MAIN INSERTED OUTPUT [OPTIONS]

ARGUMENTS:
    MAIN            Main video file
    INSERTED        Video to insert
    OUTPUT          Output video file

OPTIONS:
    --at TIME       Timestamp to insert at. Default: 0
    -v, --verbose   Show verbose output

TIME FORMATS:
    10          seconds
    10.5        seconds with decimal
    3:45        minutes:seconds
    2:03:45     hours:minutes:seconds

EXAMPLES:
    # Insert video2 at 10s into video1
    edit insert video1.mp4 video2.mp4 output.mp4 --at 10

    # Insert at 2m30s
    edit insert main.mp4 intro.mp4 output.mp4 --at 2:30
EOF
}

cmd_insert() {
    local main=""
    local inserted=""
    local output=""
    local at_time="0"

    for arg in "$@"; do
        if [[ "$arg" == "-h" || "$arg" == "--help" ]]; then
            show_insert_help
            exit 0
        fi
    done

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -v|--verbose) VERBOSE=true; shift ;;
            --at) at_time="$2"; shift 2 ;;
            -*) error "Unknown option: $1"; show_insert_help; exit 1 ;;
            *)
                if [[ -z "$main" ]]; then main="$1"
                elif [[ -z "$inserted" ]]; then inserted="$1"
                elif [[ -z "$output" ]]; then output="$1"
                else error "Unexpected argument: $1"; exit 1
                fi
                shift
                ;;
        esac
    done

    [[ -z "$main" ]] && error "Missing MAIN video" && show_insert_help && exit 1
    [[ -z "$inserted" ]] && error "Missing INSERTED video" && show_insert_help && exit 1
    [[ -z "$output" ]] && error "Missing OUTPUT" && show_insert_help && exit 1
    [[ ! -f "$main" ]] && error "File not found: $main" && exit 1
    [[ ! -f "$inserted" ]] && error "File not found: $inserted" && exit 1

    local loglevel="warning"
    [[ "$VERBOSE" == "true" ]] && loglevel="info"

    # Split main at insertion point, concat with inserted video
    local filter="[0:v]trim=start=0:end=${at_time},setpts=PTS-STARTPTS[v1];"
    filter+="[0:v]trim=start=${at_time},setpts=PTS-STARTPTS[v2];"
    filter+="[1:v]setpts=PTS-STARTPTS[v3];"
    filter+="[v1][v3][v2]concat=n=3:v=1:a=0[vout];"
    filter+="[0:a]atrim=start=0:end=${at_time}[a1];"
    filter+="[0:a]atrim=start=${at_time}[a2];"
    filter+="[1:a]asetpts=PTS-STARTPTS[a3];"
    filter+="[a1][a3][a2]concat=n=3:v=0:a=1[aout]"

    local ffmpeg_cmd=(
        ffmpeg -y -loglevel "$loglevel"
        -i "$main" -i "$inserted"
        -filter_complex "$filter"
        -map "[vout]" -map "[aout]"
        -stats "$output"
    )

    [[ "$VERBOSE" == "true" ]] && info "Filter: $filter"
    
    "${ffmpeg_cmd[@]}"
    [[ $? -eq 0 ]] && success "Created: $output" || error "Failed"
}

# ============================================================================
# audio Command - Replace or mix audio
# ============================================================================

show_audio_help() {
    cat << 'EOF'
edit audio - Replace or mix audio at a timestamp

USAGE:
    edit audio INPUT AUDIO_OR_VIDEO OUTPUT [OPTIONS]

ARGUMENTS:
    INPUT           Input video file
    AUDIO_OR_VIDEO  Audio file or video (audio extracted)
    OUTPUT          Output video file

OPTIONS:
    --at TIME       Start time for new audio. Default: 0
    --duration TIME Duration of new audio. Default: full length
    --mix LEVEL     Mix level: 0.0-1.0 or 0%-100%. Default: 1.0 (full replacement)
                    1.0 = new audio only
                    0.5 = 50/50 mix
                    0.0 = original audio only
    -v, --verbose   Show verbose output

TIME FORMATS:
    10          seconds
    10.5        seconds with decimal
    3:45        minutes:seconds
    2:03:45     hours:minutes:seconds

EXAMPLES:
    # Replace audio from 5s for 10s
    edit audio input.mp4 new_audio.mp3 output.mp4 --at 5 --duration 10

    # Mix at 50% from 1m30s
    edit audio input.mp4 music.mp3 output.mp4 --at 1:30 --mix 0.5

    # Full replacement from start
    edit audio input.mp4 narration.wav output.mp4 --mix 1.0
EOF
}

cmd_audio() {
    local input=""
    local audio_source=""
    local output=""
    local at_time="0"
    local duration=""
    local mix_level="1.0"

    for arg in "$@"; do
        if [[ "$arg" == "-h" || "$arg" == "--help" ]]; then
            show_audio_help
            exit 0
        fi
    done

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -v|--verbose) VERBOSE=true; shift ;;
            --at) at_time="$2"; shift 2 ;;
            --duration) duration="$2"; shift 2 ;;
            --mix) mix_level=$(parse_opacity "$2") || exit 1; shift 2 ;;
            -*) error "Unknown option: $1"; show_audio_help; exit 1 ;;
            *)
                if [[ -z "$input" ]]; then input="$1"
                elif [[ -z "$audio_source" ]]; then audio_source="$1"
                elif [[ -z "$output" ]]; then output="$1"
                else error "Unexpected argument: $1"; exit 1
                fi
                shift
                ;;
        esac
    done

    [[ -z "$input" ]] && error "Missing INPUT" && show_audio_help && exit 1
    [[ -z "$audio_source" ]] && error "Missing AUDIO source" && show_audio_help && exit 1
    [[ -z "$output" ]] && error "Missing OUTPUT" && show_audio_help && exit 1
    [[ ! -f "$input" ]] && error "File not found: $input" && exit 1
    [[ ! -f "$audio_source" ]] && error "File not found: $audio_source" && exit 1

    local loglevel="warning"
    [[ "$VERBOSE" == "true" ]] && loglevel="info"

    # Calculate mix weights
    local orig_weight=$(echo "1.0 $mix_level" | awk '{printf "%.2f", $1 - $2}')
    local new_weight="$mix_level"

    local filter=""
    if [[ -n "$duration" ]]; then
        # Mix at specific time for specific duration
        filter="[1:a]atrim=start=0:end=${duration},asetpts=PTS-STARTPTS,volume=${new_weight}[new];"
        filter+="[0:a]volume=${orig_weight}[orig];"
        filter+="[orig][new]amix=inputs=2:duration=first:dropout_transition=0[mixed];"
        filter+="[0:a]atrim=start=0:end=${at_time}[before];"
        filter+="[0:a]atrim=start=$(echo "$at_time $duration" | awk '{printf "%.6f", $1 + $2}')[after];"
        filter+="[before][mixed][after]concat=n=3:v=0:a=1[aout]"
    else
        # Mix from at_time to end
        filter="[1:a]asetpts=PTS-STARTPTS,volume=${new_weight}[new];"
        filter+="[0:a]volume=${orig_weight}[orig];"
        filter+="[orig][new]amix=inputs=2:duration=first:dropout_transition=0[mixed];"
        filter+="[0:a]atrim=start=0:end=${at_time}[before];"
        filter+="[before][mixed]concat=n=2:v=0:a=1[aout]"
    fi

    local ffmpeg_cmd=(
        ffmpeg -y -loglevel "$loglevel"
        -i "$input" -i "$audio_source"
        -filter_complex "$filter"
        -map "0:v" -map "[aout]"
        -c:v copy -shortest
        -stats "$output"
    )

    [[ "$VERBOSE" == "true" ]] && info "Filter: $filter"
    
    "${ffmpeg_cmd[@]}"
    [[ $? -eq 0 ]] && success "Created: $output" || error "Failed"
}

# ============================================================================
# resize Command - Resize video
# ============================================================================

show_resize_help() {
    cat << 'EOF'
edit resize - Resize video dimensions

USAGE:
    edit resize INPUT OUTPUT [OPTIONS]

ARGUMENTS:
    INPUT           Input video file
    OUTPUT          Output video file

OPTIONS:
    --width W       Target width. If omitted, calculated from height
    --height H      Target height. If omitted, calculated from width
    --scale P       Scale factor (e.g., 0.5 for half, 2.0 for double)
    -v, --verbose   Show verbose output

EXAMPLES:
    # Resize to 1280x720
    edit resize input.mp4 output.mp4 --width 1280 --height 720

    # Resize to half size
    edit resize input.mp4 output.mp4 --scale 0.5

    # Resize to 720p width (height calculated)
    edit resize input.mp4 output.mp4 --width 1280
EOF
}

cmd_resize() {
    local input=""
    local output=""
    local target_width=""
    local target_height=""
    local scale=""

    for arg in "$@"; do
        if [[ "$arg" == "-h" || "$arg" == "--help" ]]; then
            show_resize_help
            exit 0
        fi
    done

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -v|--verbose) VERBOSE=true; shift ;;
            --width) target_width="$2"; shift 2 ;;
            --height) target_height="$2"; shift 2 ;;
            --scale) scale="$2"; shift 2 ;;
            -*) error "Unknown option: $1"; show_resize_help; exit 1 ;;
            *)
                if [[ -z "$input" ]]; then input="$1"
                elif [[ -z "$output" ]]; then output="$1"
                else error "Unexpected argument: $1"; exit 1
                fi
                shift
                ;;
        esac
    done

    [[ -z "$input" ]] && error "Missing INPUT" && show_resize_help && exit 1
    [[ -z "$output" ]] && error "Missing OUTPUT" && show_resize_help && exit 1
    [[ ! -f "$input" ]] && error "File not found: $input" && exit 1
    [[ -z "$target_width" && -z "$target_height" && -z "$scale" ]] && error "Specify --width, --height, or --scale" && exit 1

    local loglevel="warning"
    [[ "$VERBOSE" == "true" ]] && loglevel="info"

    # Get current dimensions
    local cur_width cur_height
    cur_width=$(get_video_width "$input")
    cur_height=$(get_video_height "$input")

    # Calculate dimensions
    if [[ -n "$scale" ]]; then
        target_width=$(echo "$cur_width $scale" | awk '{printf "%.0f", $1 * $2}')
        target_height=$(echo "$cur_height $scale" | awk '{printf "%.0f", $1 * $2}')
    elif [[ -n "$target_width" && -z "$target_height" ]]; then
        target_height=$(echo "$cur_height $target_width $cur_width" | awk '{printf "%.0f", $1 * $2 / $3}')
    elif [[ -z "$target_width" && -n "$target_height" ]]; then
        target_width=$(echo "$cur_width $target_height $cur_height" | awk '{printf "%.0f", $1 * $2 / $3}')
    fi

    # Make dimensions even (required by many codecs)
    target_width=$(( target_width / 2 * 2 ))
    target_height=$(( target_height / 2 * 2 ))

    info "Resizing: ${cur_width}x${cur_height} -> ${target_width}x${target_height}"

    local ffmpeg_cmd=(
        ffmpeg -y -loglevel "$loglevel"
        -i "$input"
        -vf "scale=${target_width}:${target_height}"
        -c:a copy -stats "$output"
    )

    [[ "$VERBOSE" == "true" ]] && info "Command: ${ffmpeg_cmd[*]}"
    
    "${ffmpeg_cmd[@]}"
    [[ $? -eq 0 ]] && success "Created: $output" || error "Failed"
}

# ============================================================================
# Main
# ============================================================================

main() {
    # Check for no arguments
    if [[ $# -eq 0 ]]; then
        show_help
        exit 0
    fi
    
    # Parse global options
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                show_help
                exit 0
                ;;
            -y|--yes)
                AUTO_YES=true
                shift
                ;;
            -V|--version)
                echo "edit version $VERSION"
                exit 0
                ;;
            -v|--verbose)
                VERBOSE=true
                shift
                ;;
            *)
                break
                ;;
        esac
    done
    
    # Check dependencies
    check_dependencies
    
    # Parse command
    local command="$1"
    shift
    
    case "$command" in
        pic|picture|image)
            cmd_pic "$@"
            ;;
        text)
            cmd_text "$@"
            ;;
        stat|stats)
            cmd_stat "$@"
            ;;
        crop)
            cmd_crop "$@"
            ;;
        cut)
            cmd_cut "$@"
            ;;
        insert)
            cmd_insert "$@"
            ;;
        audio)
            cmd_audio "$@"
            ;;
        resize)
            cmd_resize "$@"
            ;;
        *)
            error "Unknown command: $command"
            echo ""
            echo "Available commands: pic, text, stat, crop, cut, insert, audio, resize"
            echo "Run 'edit --help' for more information."
            exit 1
            ;;
    esac
}

main "$@"

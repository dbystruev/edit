# ============================================================================
# split Command
# ============================================================================

cmd_split() {
    local input="" times="" prefix=""
    for arg in "$@"; do [[ "$arg" == "-h" || "$arg" == "--help" ]] && show_split_help && exit 0; done
    while [[ $# -gt 0 ]]; do
        case "$1" in -v|--verbose) VERBOSE=true; shift;; --times) times="$2"; shift 2;; --prefix) prefix="$2"; shift 2;; -*) error "Unknown: $1"; exit 1;; *) [[ -z "$input" ]] && input="$1"; shift;; esac
    done
    [[ -z "$input" ]] && error "Usage: edit split INPUT --times 10,30,60" && exit 1
    [[ ! -f "$input" ]] && error "File not found: $input" && exit 1
    [[ -z "$times" ]] && error "Specify --times with comma-separated split points" && exit 1

    # Default prefix is input filename without extension
    [[ -z "$prefix" ]] && prefix="${input%.*}"
    local ext="${input##*.}"

    # Get video duration
    local vid_duration
    vid_duration=$(get_duration "$input")

    # Parse split times into array
    IFS=',' read -ra split_times <<< "$times"
    
    # Build list of segment boundaries: 0, t1, t2, ..., duration
    local boundaries=(0 "${split_times[@]}" "$vid_duration")
    
    local loglevel="warning"; [[ "$VERBOSE" == "true" ]] && loglevel="info"
    
    info "Splitting into ${#boundaries[@]} segments at times: ${split_times[*]}"
    
    for ((i=0; i<${#boundaries[@]}-1; i++)); do
        local start_time="${boundaries[$i]}"
        local end_time="${boundaries[$((i+1))]}"
        local segment_num=$(printf "%03d" $((i+1)))
        local output="${prefix}_${segment_num}.${ext}"
        
        info "Segment $segment_num: ${start_time}s to ${end_time}s -> $output"
        ffmpeg -y -loglevel "$loglevel" -i "$input" -ss "$start_time" -to "$end_time" -c:v libx264 -crf 23 -force_key_frames "expr:gte(t,$start_time)" -c:a aac -stats "$output" && success "Created: $output" || error "Failed to create $output"
    done
}

# ============================================================================
# join Command
# ============================================================================

cmd_join() {
    local inputs=()
    local output=""
    local has_verbose=false
    
    for arg in "$@"; do [[ "$arg" == "-h" || "$arg" == "--help" ]] && show_join_help && exit 0; done
    
    # Parse arguments - collect all inputs except the last one which is output
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -v|--verbose) VERBOSE=true; shift;;
            -*) error "Unknown option: $1"; exit 1;;
            *) inputs+=("$1"); shift;;
        esac
    done
    
    # Last argument is output, rest are inputs
    [[ ${#inputs[@]} -lt 2 ]] && error "Usage: edit join INPUT1 INPUT2 [INPUT3...] OUTPUT" && exit 1
    output="${inputs[-1]}"
    unset 'inputs[-1]'  # Remove last element (output)
    
    [[ ! -f "${inputs[0]}" ]] && error "File not found: ${inputs[0]}" && exit 1
    
    local loglevel="warning"; [[ "$VERBOSE" == "true" ]] && loglevel="info"
    
    # Create concat list file with absolute paths
    local concat_file=$(mktemp /tmp/concat_XXXXXX.txt)
    for input in "${inputs[@]}"; do
        local abs_path
        abs_path=$(cd "$(dirname "$input")" && pwd)/$(basename "$input")
        echo "file '$abs_path'" >> "$concat_file"
    done
    
    info "Joining ${#inputs[@]} clips into $output"
    
    ffmpeg -y -loglevel "$loglevel" -f concat -safe 0 -i "$concat_file" -c:v libx264 -crf 23 -c:a aac -stats "$output"
    local result=$?
    
    rm -f "$concat_file"
    
    [[ $result -eq 0 ]] && success "Created: $output" || error "Failed"
    return $result
}

# ============================================================================
# transcribe Command
# ============================================================================

cmd_transcribe() {
    local input="" model="small" language="" format="srt" output_file=""
    for arg in "$@"; do [[ "$arg" == "-h" || "$arg" == "--help" ]] && show_transcribe_help && exit 0; done
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -v|--verbose) VERBOSE=true; shift;;
            --model) model="$2"; shift 2;;
            --language) language="$2"; shift 2;;
            --format) format="$2"; shift 2;;
            --output) output_file="$2"; shift 2;;
            -*) error "Unknown option: $1"; exit 1;;
            *) [[ -z "$input" ]] && input="$1"; shift;;
        esac
    done
    
    [[ -z "$input" ]] && error "Usage: edit transcribe INPUT [--model small] [--format srt]" && exit 1
    [[ ! -f "$input" ]] && error "File not found: $input" && exit 1
    
    # Check if whisper is installed (as Python module or command)
    local whisper_found=false
    if command -v whisper &>/dev/null; then
        whisper_found=true
    elif python3 -c "import whisper" &>/dev/null; then
        whisper_found=true
    elif python -c "import whisper" &>/dev/null; then
        whisper_found=true
    fi
    
    if [[ "$whisper_found" == "false" ]]; then
        warn "whisper not found"
        if [[ "$AUTO_YES" == "true" ]] || confirm "Install openai-whisper?"; then
            info "Installing openai-whisper..."
            if command -v pip3 &>/dev/null; then
                pip3 install openai-whisper
            elif command -v pip &>/dev/null; then
                pip install openai-whisper
            else
                error "pip not found. Install Python first: brew install python"
                exit 1
            fi
            
            # Verify installation
            if ! python3 -c "import whisper" &>/dev/null && ! python -c "import whisper" &>/dev/null; then
                error "Installation failed. Try manually: pip install openai-whisper"
                exit 1
            fi
            success "whisper installed successfully"
        else
            error "Cannot continue without whisper"
            exit 1
        fi
    fi
    
    # Default output file
    [[ -z "$output_file" ]] && output_file="${input%.*}"
    
    local loglevel=""
    [[ "$VERBOSE" == "true" ]] && loglevel="--verbose True"
    
    # Build whisper command - use python3 -m whisper if whisper command not found
    local whisper_bin="whisper"
    if ! command -v whisper &>/dev/null; then
        whisper_bin="python3 -m whisper"
    fi
    
    local whisper_cmd="$whisper_bin \"$input\" --model $model --output_format $format --output_dir \"$(dirname "$output_file")\" $loglevel"
    
    # Add language if specified
    [[ -n "$language" ]] && whisper_cmd+=" --language $language"
    
    info "Transcribing with model: $model"
    [[ -n "$language" ]] && info "Language: $language" || info "Language: auto-detect"
    
    eval "$whisper_cmd"
    
    # Rename output file if needed
    local expected_output="${output_file}.${format}"
    local whisper_output="$(dirname "$output_file")/$(basename "$input" .*).${format}"
    
    if [[ -f "$whisper_output" && "$whisper_output" != "$expected_output" ]]; then
        mv "$whisper_output" "$expected_output"
    fi
    
    [[ -f "$expected_output" ]] && success "Created: $expected_output" || error "Transcription failed"
}

# ============================================================================
# Main
# ============================================================================

main() {
    [[ $# -eq 0 ]] && show_help && exit 0
    while [[ $# -gt 0 ]]; do
        case "$1" in -h|--help) show_help; exit 0;; -y|--yes) AUTO_YES=true; shift;; -V|--version) echo "edit version $VERSION"; exit 0;; -v|--verbose) VERBOSE=true; shift;; *) break;; esac
    done
    check_dependencies
    local command="$1"; shift
    case "$command" in
        pic|picture|image) cmd_pic "$@";;
        text) cmd_text "$@";;
        stat|stats) cmd_stat "$@";;
        crop) cmd_crop "$@";;
        cut) cmd_cut "$@";;
        insert) cmd_insert "$@";;
        audio) cmd_audio "$@";;
        fade-in|fadein) cmd_fadein "$@";;
        fade-out|fadeout) cmd_fadeout "$@";;
        resize) cmd_resize "$@";;
        frame) cmd_frame "$@";;
        dedup) cmd_dedup "$@";;
        split) cmd_split "$@";;
        join|concat|cat) cmd_join "$@";;
        transcribe|whisper) cmd_transcribe "$@";;
        *) error "Unknown: $command"; echo "Commands: pic, text, stat, crop, cut, insert, audio, fade-in, fade-out, resize, frame, dedup, split, join, transcribe"; exit 1;;
    esac
}

main "$@"

#!/usr/bin/env bash
set -euo pipefail

# edit - A command-line video editing toolkit powered by ffmpeg
# Repository: https://github.com/dbystruev/edit

VERSION="0.3.0"
AUTO_YES=false
VERBOSE=false

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# ============================================================================
# Utility Functions
# ============================================================================

info() {
    echo -e "${BLUE}[INFO]${NC} $*"
}

success() {
    echo -e "${GREEN}[OK]${NC} $*"
}

warn() {
    echo -e "${YELLOW}[WARN]${NC} $*"
}

error() {
    echo -e "${RED}[ERROR]${NC} $*" >&2
}

confirm() {
    local prompt="$1"
    if [[ "$AUTO_YES" == "true" ]]; then
        return 0
    fi
    read -rp "$prompt [y/N] " response
    case "$response" in
        [yY][eE][sS]|[yY]) return 0 ;;
        *) return 1 ;;
    esac
}

# ============================================================================
# Dependency Management
# ============================================================================

check_command() {
    command -v "$1" &>/dev/null
}

install_package() {
    local package="$1"
    
    if [[ "$AUTO_YES" == "true" ]]; then
        info "Auto-installing $package..."
    else
        if ! confirm "Install $package?"; then
            error "Cannot continue without $package"
            return 1
        fi
    fi
    
    # Detect package manager and install
    if check_command apt-get; then
        sudo apt-get update -qq && sudo apt-get install -y -qq "$package"
    elif check_command brew; then
        brew install "$package"
    elif check_command choco; then
        choco install "$package" -y
    elif check_command winget; then
        winget install "$package" --accept-source-agreements --accept-package-agreements
    elif check_command dnf; then
        sudo dnf install -y "$package"
    elif check_command yum; then
        sudo yum install -y "$package"
    elif check_command pacman; then
        sudo pacman -S --noconfirm "$package"
    elif check_command zypper; then
        sudo zypper install -y "$package"
    else
        error "No supported package manager found. Please install $package manually."
        return 1
    fi
}

check_dependencies() {
    local missing=()
    
    # Check ffmpeg
    if ! check_command ffmpeg; then
        missing+=("ffmpeg")
    fi
    
    # Check ffprobe
    if ! check_command ffprobe; then
        missing+=("ffprobe")
    fi
    
    if [[ ${#missing[@]} -gt 0 ]]; then
        warn "Missing required dependencies: ${missing[*]}"
        
        for pkg in "${missing[@]}"; do
            # Map command names to package names
            local pkg_name="$pkg"
            case "$pkg" in
                ffprobe) pkg_name="ffmpeg" ;;
            esac
            
            if ! install_package "$pkg_name"; then
                exit 1
            fi
        done
        
        # Verify installation
        for pkg in "${missing[@]}"; do
            if ! check_command "$pkg"; then
                error "Failed to install $pkg. Please install manually."
                exit 1
            fi
        done
        
        success "Dependencies installed successfully"
    fi
}


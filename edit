# ============================================================================
# Coordinate Parsing
# ============================================================================

# Parse a single coordinate (pixels or percentage)
parse_coord() {
    local coord="$1"
    local total="$2"
    
    # Check if percentage
    if [[ "$coord" =~ ^([0-9]+\.?[0-9]*)%$ ]]; then
        local pct="${BASH_REMATCH[1]}"
        echo "$pct" | awk -v total="$total" '{printf "%.0f", $1/100*total}'
        return 0
    fi
    
    # Check if pixel value
    if [[ "$coord" =~ ^[0-9]+\.?[0-9]*$ ]]; then
        echo "$coord"
        return 0
    fi
    
    error "Invalid coordinate format: $coord (use pixels or percentage)"
    return 1
}

# Parse rectangle string "X1,Y1 X2,Y2" to pixels
parse_rect() {
    local rect_str="$1"
    local video_width="$2"
    local video_height="$3"
    
    # Split by space to get two corners
    local corners
    IFS=' ' read -ra corners <<< "$rect_str"
    
    if [[ ${#corners[@]} -ne 2 ]]; then
        error "Rectangle requires exactly two corners: X1,Y1 X2,Y2"
        return 1
    fi
    
    # Parse first corner
    IFS=',' read -r x1 y1 <<< "${corners[0]}"
    IFS=',' read -r x2 y2 <<< "${corners[1]}"
    
    # Convert percentages to pixels
    # X coordinates use video_width, Y coordinates use video_height
    x1=$(parse_coord "$x1" "$video_width") || return 1
    y1=$(parse_coord "$y1" "$video_height") || return 1
    x2=$(parse_coord "$x2" "$video_width") || return 1
    y2=$(parse_coord "$y2" "$video_height") || return 1
    
    # Ensure x1,y1 is top-left and x2,y2 is bottom-right
    local min_x=$(( x1 < x2 ? x1 : x2 ))
    local min_y=$(( y1 < y2 ? y1 : y2 ))
    local max_x=$(( x1 > x2 ? x1 : x2 ))
    local max_y=$(( y1 > y2 ? y1 : y2 ))
    
    local width=$(( max_x - min_x ))
    local height=$(( max_y - min_y ))
    
    echo "$min_x $min_y $max_x $max_y $width $height"
}

# ============================================================================
# Time/Frame Parsing
# ============================================================================

# Convert time string to seconds
# Supports:
#   - Frame number: f120
#   - Seconds: 10, 10.5, 0225
#   - Minutes:Seconds: 3:45, 03:45
#   - Hours:Minutes:Seconds: 2:03:45, 02:03:45
#   - Internal format: seconds:10, frame:120
time_to_seconds() {
    local time_str="$1"
    local fps="${2:-}"
    
    # Handle internal format (already parsed)
    if [[ "$time_str" =~ ^seconds:([0-9]+\.?[0-9]*)$ ]]; then
        echo "${BASH_REMATCH[1]}"
        return 0
    fi
    if [[ "$time_str" =~ ^frame:([0-9]+\.?[0-9]*)$ ]]; then
        if [[ -n "$fps" ]]; then
            echo "${BASH_REMATCH[1]}" | awk -v fps="$fps" '{printf "%.6f", $1/fps}'
        else
            echo "${BASH_REMATCH[1]}"
        fi
        return 0
    fi
    
    # Frame number (prefixed with 'f')
    if [[ "$time_str" =~ ^f([0-9]+\.?[0-9]*)$ ]]; then
        if [[ -n "$fps" ]]; then
            echo "${BASH_REMATCH[1]}" | awk -v fps="$fps" '{printf "%.6f", $1/fps}'
        else
            echo "${BASH_REMATCH[1]}"
        fi
        return 0
    fi
    
    # Hours:Minutes:Seconds (two colons)
    if [[ "$time_str" =~ ^([0-9]+):([0-9]+):([0-9]+\.?[0-9]*)$ ]]; then
        local h="${BASH_REMATCH[1]}"
        local m="${BASH_REMATCH[2]}"
        local s="${BASH_REMATCH[3]}"
        echo "$h $m $s" | awk '{printf "%.6f", $1*3600 + $2*60 + $3}'
        return 0
    fi
    
    # Minutes:Seconds (one colon)
    if [[ "$time_str" =~ ^([0-9]+):([0-9]+\.?[0-9]*)$ ]]; then
        local m="${BASH_REMATCH[1]}"
        local s="${BASH_REMATCH[2]}"
        echo "$m $s" | awk '{printf "%.6f", $1*60 + $2}'
        return 0
    fi
    
    # Plain seconds (with optional decimal)
    if [[ "$time_str" =~ ^[0-9]+\.?[0-9]*$ ]]; then
        echo "$time_str"
        return 0
    fi
    
    error "Invalid time format: $time_str"
    return 1
}

# Parse time for pic/text commands (stores as internal format)
parse_time() {
    local time_str="$1"
    
    # Check if frame number (prefixed with 'f')
    if [[ "$time_str" =~ ^f([0-9]+\.?[0-9]*)$ ]]; then
        echo "frame:${BASH_REMATCH[1]}"
        return 0
    fi
    
    # Validate and store as seconds
    local seconds
    seconds=$(time_to_seconds "$time_str") || return 1
    echo "seconds:$seconds"
    return 0
}

# ============================================================================
# Video Info Helpers
# ============================================================================

get_video_info() {
    local input="$1"
    local field="$2"
    
    ffprobe -v quiet -select_streams v:0 \
        -show_entries "stream=$field" \
        -of csv=p=0 "$input" 2>/dev/null
}

get_video_width() {
    get_video_info "$1" "width"
}

get_video_height() {
    get_video_info "$1" "height"
}

get_video_fps() {
    local fps_str
    fps_str=$(get_video_info "$1" "r_frame_rate")
    
    # Convert fraction to decimal
    if [[ "$fps_str" =~ ^([0-9]+)/([0-9]+)$ ]]; then
        echo "${BASH_REMATCH[1]} ${BASH_REMATCH[2]}" | awk '{printf "%.6f", $1/$2}'
    else
        echo "$fps_str"
    fi
}

get_duration() {
    ffprobe -v quiet -show_entries format=duration \
        -of csv=p=0 "$1" 2>/dev/null
}

# ============================================================================
# Opacity Parsing
# ============================================================================

parse_opacity() {
    local opacity_str="$1"
    
    # Handle percentage
    if [[ "$opacity_str" =~ ^([0-9]+\.?[0-9]*)%$ ]]; then
        echo "${BASH_REMATCH[1]}" | awk '{printf "%.2f", $1/100}'
        return 0
    fi
    
    # Handle decimal 0.0-1.0
    if [[ "$opacity_str" =~ ^[0-9]+\.?[0-9]*$ ]]; then
        echo "$opacity_str"
        return 0
    fi
    
    error "Invalid opacity format: $opacity_str (use 0.0-1.0 or 0%-100%)"
    return 1
}

# ============================================================================
# Fade Duration Calculation
# ============================================================================

get_fade_duration() {
    local mode="$1"
    
    case "$mode" in
        none) echo "0" ;;
        quick) echo "0.5" ;;
        slow) echo "1.5" ;;
        *) error "Unknown fade mode: $mode"; return 1 ;;
    esac
}

# ============================================================================
# Parameter File Loading
# ============================================================================

load_params_file() {
    local file="$1"
    local -n result_array=$2
    
    if [[ ! -f "$file" ]]; then
        error "Parameter file not found: $file"
        return 1
    fi
    
    while IFS= read -r line || [[ -n "$line" ]]; do
        # Skip empty lines and comments
        [[ -z "$line" || "$line" =~ ^# ]] && continue
        
        # Trim whitespace
        line=$(echo "$line" | xargs)
        
        # Split line into words
        local words
        read -ra words <<< "$line"
        
        # Add to result array
        for word in "${words[@]}"; do
            result_array+=("$word")
        done
    done < "$file"
}

# ============================================================================
# pic Command - Insert Picture
# ============================================================================

cmd_pic() {
    local input=""
    local output=""
    local pictures=()      # Array of picture files
    local pic_ats=()       # Array of start times per picture
    local pic_durations=() # Array of durations per picture
    local pic_rects=()     # Array of rectangles per picture
    local global_mode="aspect-fit"
    local global_opacity="1.0"
    local global_transparent_bg="yes"
    
    # Inherited values for new pictures (start with defaults, then inherit from previous)
    local at="seconds:0"
    local duration="seconds:3"
    local rect=""
    
    # Check for help first
    for arg in "$@"; do
        if [[ "$arg" == "-h" || "$arg" == "--help" ]]; then
            show_pic_help
            exit 0
        fi
    done
    
    # Parse arguments - support per-image parameters
    # Each image inherits parameters from the previous one
    # Syntax: edit pic input.mp4 output.mp4 img1.png --at 0 --rect ... img2.png --at 5 ...
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -v|--verbose)
                VERBOSE=true
                shift
                ;;
            --at)
                at=$(parse_time "$2") || exit 1
                # Update last picture if it exists (options after image file)
                if [[ ${#pictures[@]} -gt 0 ]]; then
                    local last_idx=$(( ${#pictures[@]} - 1 ))
                    pic_ats[$last_idx]="$at"
                fi
                shift 2
                ;;
            --duration)
                duration=$(parse_time "$2") || exit 1
                if [[ ${#pictures[@]} -gt 0 ]]; then
                    local last_idx=$(( ${#pictures[@]} - 1 ))
                    pic_durations[$last_idx]="$duration"
                fi
                shift 2
                ;;
            --rect)
                rect="$2 $3"
                if [[ ${#pictures[@]} -gt 0 ]]; then
                    local last_idx=$(( ${#pictures[@]} - 1 ))
                    pic_rects[$last_idx]="$rect"
                fi
                shift 3
                ;;
            --mode)
                global_mode="$2"
                shift 2
                ;;
            --opacity)
                global_opacity=$(parse_opacity "$2") || exit 1
                shift 2
                ;;
            --transparent-bg)
                global_transparent_bg="$2"
                shift 2
                ;;
            -*)
                error "Unknown option: $1"
                show_pic_help
                exit 1
                ;;
            *)
                # Check if this looks like an image file
                if [[ "$1" =~ \.(jpg|jpeg|png|gif|bmp|tiff|webp)$ ]]; then
                    # Add new picture with current inherited parameters
                    pictures+=("$1")
                    pic_ats+=("$at")
                    pic_durations+=("$duration")
                    pic_rects+=("$rect")
                elif [[ -z "$input" ]]; then
                    input="$1"
                elif [[ -z "$output" ]]; then
                    output="$1"
                else
                    error "Unexpected argument: $1"
                    show_pic_help
                    exit 1
                fi
                shift
                ;;
        esac
    done
    
    # Validate required arguments
    local missing=()
    [[ -z "$input" ]] && missing+=("INPUT video file")
    [[ -z "$output" ]] && missing+=("OUTPUT video file")
    [[ ${#pictures[@]} -eq 0 ]] && missing+=("PICTURE file(s)")
    
    # Check that all pictures have rectangles
    for i in "${!pictures[@]}"; do
        if [[ -z "${pic_rects[$i]}" ]]; then
            missing+=("--rect for ${pictures[$i]}")
        fi
    done
    
    if [[ ${#missing[@]} -gt 0 ]]; then
        error "Missing required arguments:"
        for m in "${missing[@]}"; do
            echo "  - $m"
        done
        echo ""
        show_pic_help
        exit 1
    fi
    
    # Validate input files exist
    [[ ! -f "$input" ]] && error "Input video not found: $input" && exit 1
    for pic in "${pictures[@]}"; do
        [[ ! -f "$pic" ]] && error "Picture file not found: $pic" && exit 1
    done
    
    # Get video dimensions
    local vid_width vid_height
    vid_width=$(get_video_width "$input") || { error "Failed to read video info"; exit 1; }
    vid_height=$(get_video_height "$input") || { error "Failed to read video info"; exit 1; }
    
    if [[ -z "$vid_width" || -z "$vid_height" ]]; then
        error "Could not determine video dimensions"
        exit 1
    fi
    
    info "Video: ${vid_width}x${vid_height}"
    
    # Get video fps
    local fps
    fps=$(get_video_fps "$input")
    
    # Build input arguments
    local input_args=()
    input_args+=(-i "$input")
    for pic in "${pictures[@]}"; do
        input_args+=(-i "$pic")
    done
    
    # Build filter complex with per-image parameters
    local filters=""
    local last_label="[0:v]"
    local input_idx=1
    
    for i in "${!pictures[@]}"; do
        local pic_idx=$input_idx
        local pic_at="${pic_ats[$i]}"
        local pic_duration="${pic_durations[$i]}"
        local pic_rect="${pic_rects[$i]}"
        
        # Parse this picture's rectangle
        local coords
        coords=$(parse_rect "$pic_rect" "$vid_width" "$vid_height") || exit 1
        
        local x1 y1 x2 y2 rect_w rect_h
        read -r x1 y1 x2 y2 rect_w rect_h <<< "$coords"
        
        # Convert time values to seconds
        local start_seconds duration_seconds
        start_seconds=$(time_to_seconds "$pic_at" "$fps")
        duration_seconds=$(time_to_seconds "$pic_duration" "$fps")
        
        local end_seconds
        end_seconds=$(echo "$start_seconds $duration_seconds" | awk '{printf "%.6f", $1 + $2}')
        
        info "${pictures[$i]}: at=${start_seconds}s, duration=${duration_seconds}s, rect=${x1},${y1}-${x2},${y2}"
        
        # Use unique label for each overlay
        local ovr_label="[ovr${i}]"
        
        # Scale and format the picture
        case "$global_mode" in
            aspect-fit)
                filters+="[${pic_idx}:v]scale=${rect_w}:${rect_h}:force_original_aspect_ratio=decrease,pad=${rect_w}:${rect_h}:(ow-iw)/2:(oh-ih)/2:color=black@0,format=rgba${ovr_label};"
                ;;
            aspect-fill)
                filters+="[${pic_idx}:v]scale=${rect_w}:${rect_h}:force_original_aspect_ratio=increase,crop=${rect_w}:${rect_h},format=rgba${ovr_label};"
                ;;
            scale)
                filters+="[${pic_idx}:v]scale=${rect_w}:${rect_h},format=rgba${ovr_label};"
                ;;
            *)
                error "Unknown mode: $global_mode (use aspect-fit, aspect-fill, or scale)"
                exit 1
                ;;
        esac
        
        # Apply opacity
        if [[ "$global_opacity" != "1.0" ]]; then
            filters+="${ovr_label}colorchannelmixer=aa=${global_opacity}${ovr_label};"
        fi
        
        # Overlay onto video with enable timing
        local next_label="[v${input_idx}]"
        filters+="${last_label}${ovr_label}overlay=${x1}:${y1}:enable='between(t\\,${start_seconds}\\,${end_seconds})'${next_label};"
        last_label="${next_label}"
        
        input_idx=$((input_idx + 1))
    done
    
    # Remove trailing semicolon
    filters="${filters%;}"
    
    # Execute ffmpeg
    info "Processing ${#pictures[@]} image(s)..."
    
    if [[ "$VERBOSE" == "true" ]]; then
        info "Filter complex:"
        echo "$filters" | sed 's/;/;\n/g'
        echo ""
    fi
    
    local loglevel="warning"
    if [[ "$VERBOSE" == "true" ]]; then
        loglevel="info"
    fi
    
    local ffmpeg_cmd=(
        ffmpeg -y
        -loglevel "$loglevel"
        "${input_args[@]}"
        -filter_complex "$filters"
        -map "${last_label}"
        -map "0:a?"
        -c:a copy
        -stats
        "$output"
    )
    
    if [[ "$VERBOSE" == "true" ]]; then
        info "FFmpeg command:"
        echo "${ffmpeg_cmd[@]}" | sed 's/ -/ \\\n  -/g'
        echo ""
    fi
    
    "${ffmpeg_cmd[@]}"
    
    if [[ $? -eq 0 ]]; then
        success "Created: $output"
    else
        error "Failed to process video"
        exit 1
    fi
}

# ============================================================================
# text Command - Insert Text
# ============================================================================

cmd_text() {
    local input=""
    local output=""
    local text=""
    local at="seconds:0"
    local duration="seconds:3"
    local rect=""
    local color="white"
    local size="48"
    local font=""
    local bold=false
    local italic=false
    local outline=""
    local shadow=""
    local bg_color=""
    local bg_padding="0"
    local param_file=""

    # Check for help first
    for arg in "$@"; do
        if [[ "$arg" == "-h" || "$arg" == "--help" ]]; then
            show_text_help
            exit 0
        fi
    done
    
    # Check if drawtext filter is available
    if ! ffmpeg -filters 2>/dev/null | grep -q drawtext; then
        error "drawtext filter not available in your ffmpeg installation."
        error "On macOS, reinstall ffmpeg with: brew reinstall ffmpeg"
        error "Or install: brew install ffmpeg --with-freetype"
        exit 1
    fi
    
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -v|--verbose)
                VERBOSE=true
                shift
                ;;
            --at)
                at=$(parse_time "$2") || exit 1
                shift 2
                ;;
            --duration)
                duration=$(parse_time "$2") || exit 1
                shift 2
                ;;
            --appear)
                appear="$2"
                shift 2
                ;;
            --disappear)
                disappear="$2"
                shift 2
                ;;
            --rect)
                rect="$2 $3"
                shift 3
                ;;
            --color)
                color="$2"
                shift 2
                ;;
            --size)
                size="$2"
                shift 2
                ;;
            --font)
                font="$2"
                shift 2
                ;;
            --bold)
                bold=true
                shift
                ;;
            --italic)
                italic=true
                shift
                ;;
            --outline)
                outline="$2"
                shift 2
                ;;
            --shadow)
                shadow="$2"
                shift 2
                ;;
            --bg-color)
                bg_color="$2"
                shift 2
                ;;
            --bg-padding)
                bg_padding="$2"
                shift 2
                ;;
            --file)
                param_file="$2"
                shift 2
                ;;
            -*)
                error "Unknown option: $1"
                show_text_help
                exit 1
                ;;
            *)
                if [[ -z "$input" ]]; then
                    input="$1"
                elif [[ -z "$output" ]]; then
                    output="$1"
                elif [[ -z "$text" ]]; then
                    text="$1"
                else
                    error "Unexpected argument: $1"
                    exit 1
                fi
                shift
                ;;
        esac
    done
    
    # Load parameters from file if specified
    if [[ -n "$param_file" ]]; then
        local file_params=()
        load_params_file "$param_file" file_params || exit 1
        
        set -- "${file_params[@]}"
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --at) at=$(parse_time "$2") || exit 1; shift 2 ;;
                --duration) duration=$(parse_time "$2") || exit 1; shift 2 ;;
                --appear) appear="$2"; shift 2 ;;
                --disappear) disappear="$2"; shift 2 ;;
                --rect) rect="$2 $3"; shift 3 ;;
                --color) color="$2"; shift 2 ;;
                --size) size="$2"; shift 2 ;;
                --font) font="$2"; shift 2 ;;
                --bold) bold=true; shift ;;
                --italic) italic=true; shift ;;
                --outline) outline="$2"; shift 2 ;;
                --shadow) shadow="$2"; shift 2 ;;
                --bg-color) bg_color="$2"; shift 2 ;;
                --bg-padding) bg_padding="$2"; shift 2 ;;
                *) shift ;;
            esac
        done
    fi
    
    # Validate required arguments
    local missing=()
    [[ -z "$input" ]] && missing+=("INPUT video file")
    [[ -z "$output" ]] && missing+=("OUTPUT video file")
    [[ -z "$text" ]] && missing+=("TEXT string")
    [[ -z "$rect" ]] && missing+=("--rect X1,Y1 X2,Y2")
    
    if [[ ${#missing[@]} -gt 0 ]]; then
        error "Missing required arguments:"
        for m in "${missing[@]}"; do
            echo "  - $m"
        done
        echo ""
        show_text_help
        exit 1
    fi
    
    # Validate input file
    [[ ! -f "$input" ]] && error "Input video not found: $input" && exit 1
    
    # Get video info
    local width height fps
    width=$(get_video_width "$input") || { error "Failed to read video info"; exit 1; }
    height=$(get_video_height "$input") || { error "Failed to read video info"; exit 1; }
    fps=$(get_video_fps "$input")
    
    info "Video: ${width}x${height}"
    
    # Parse rectangle
    local coords
    coords=$(parse_rect "$rect" "$width" "$height") || exit 1
    
    local x1 y1 x2 y2
    read -r x1 y1 x2 y2 _ _ <<< "$coords"
    
    local rect_w=$(( x2 - x1 ))
    local rect_h=$(( y2 - y1 ))
    
    # Convert time values
    local start_seconds duration_seconds
    start_seconds=$(time_to_seconds "$at" "$fps")
    duration_seconds=$(time_to_seconds "$duration" "$fps")
    
    # Calculate fade durations
    local fade_in_duration fade_out_duration
    fade_in_duration=$(get_fade_duration "$appear")
    fade_out_duration=$(get_fade_duration "$disappear")
    
    info "Start: ${start_seconds}s, Duration: ${duration_seconds}s"
    
    # Escape text for ffmpeg drawtext filter
    # Replace special chars: ' -> \', : -> \:, \ -> \\, etc.
    local escaped_text="$text"
    escaped_text="${escaped_text//\\/\\\\}"    # Backslash first
    escaped_text="${escaped_text//\'/\\\'}"    # Single quotes
    escaped_text="${escaped_text//:/\\:}"      # Colons (filter separator)
    escaped_text="${escaped_text//;/\\;}"      # Semicolons
    escaped_text="${escaped_text//[/\\[}"      # Brackets
    escaped_text="${escaped_text//]/\\]}"      # Brackets
    
    # Build drawtext filter
    local drawtext_opts="text='${escaped_text}'"
    drawtext_opts+=":fontsize=${size}"
    drawtext_opts+=":fontcolor=${color}"
    
    # Font
    if [[ -n "$font" ]]; then
        drawtext_opts+=":font='${font}'"
    fi
    
    # Style
    if [[ "$bold" == "true" ]]; then
        drawtext_opts+=":fontcolor_expr=${color}@1|bold"
    fi
    if [[ "$italic" == "true" ]]; then
        drawtext_opts+=":fontcolor_expr=${color}@1|italic"
    fi
    
    # Position - center in rectangle
    drawtext_opts+=":x=${x1}+(${rect_w}-text_w)/2:y=${y1}+(${rect_h}-text_h)/2"
    
    # Text box / background
    if [[ -n "$bg_color" ]]; then
        drawtext_opts+=":box=1:boxcolor=${bg_color}@0.8:boxborderw=${bg_padding}"
    fi
    
    # Outline
    if [[ -n "$outline" ]]; then
        IFS=':' read -r outline_width outline_color <<< "$outline"
        drawtext_opts+=":borderw=${outline_width}:bordercolor=${outline_color:-black}"
    fi
    
    # Shadow
    if [[ -n "$shadow" ]]; then
        IFS=':' read -r shadow_x shadow_y shadow_color <<< "$shadow"
        drawtext_opts+=":shadowx=${shadow_x}:shadowy=${shadow_y}:shadowcolor=${shadow_color:-black}"
    fi
    
    # Time enable
    local end_seconds
    end_seconds=$(echo "$start_seconds $duration_seconds" | awk '{printf "%.6f", $1 + $2}')
    drawtext_opts+=":enable='between(t\\,${start_seconds}\\,${end_seconds})'"
    
    # Build filter chain
    local filters="[0:v]drawtext=${drawtext_opts}[out]"
    
    # Execute ffmpeg
    info "Processing..."
    
    if [[ "$VERBOSE" == "true" ]]; then
        info "Filter:"
        echo "$filters" | sed 's/:/:\n  /g'
        echo ""
    fi
    
    local loglevel="warning"
    if [[ "$VERBOSE" == "true" ]]; then
        loglevel="info"
    fi
    
    local ffmpeg_cmd=(
        ffmpeg -y
        -loglevel "$loglevel"
        -i "$input"
        -filter_complex "$filters"
        -map "[out]"
        -map "0:a?"
        -c:a copy
        -stats
        "$output"
    )
    
    if [[ "$VERBOSE" == "true" ]]; then
        info "FFmpeg command:"
        echo "${ffmpeg_cmd[@]}" | sed 's/ -/ \\\n  -/g'
        echo ""
    fi
    
    "${ffmpeg_cmd[@]}"
    
    if [[ $? -eq 0 ]]; then
        success "Created: $output"
    else
        error "Failed to process video"
        exit 1
    fi
}


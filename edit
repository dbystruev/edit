                else
                    error "Unexpected argument: $1"
                    exit 1
                fi
                shift
                ;;
        esac
    done
    
    # Validate required arguments
    local missing=()
    [[ -z "$input" ]] && missing+=("INPUT video file")
    [[ -z "$output" ]] && missing+=("OUTPUT video file")
    [[ -z "$text" ]] && missing+=("TEXT string")
    [[ -z "$rect" ]] && missing+=("--rect X1,Y1 X2,Y2")
    
    if [[ ${#missing[@]} -gt 0 ]]; then
        error "Missing required arguments:"
        for m in "${missing[@]}"; do
            echo "  - $m"
        done
        echo ""
        show_insert_text_help
        exit 1
    fi
    
    # Validate input file
    [[ ! -f "$input" ]] && error "Input video not found: $input" && exit 1
    
    # Get video info
    local width height fps
    width=$(get_video_width "$input") || { error "Failed to read video info"; exit 1; }
    height=$(get_video_height "$input") || { error "Failed to read video info"; exit 1; }
    fps=$(get_video_fps "$input")
    
    info "Video: ${width}x${height}"
    
    # Parse rectangle
    local coords
    coords=$(parse_rect "$rect" "$width" "$height") || exit 1
    
    local x1 y1 x2 y2
    read -r x1 y1 x2 y2 <<< "$coords"
    
    local rect_w=$(( x2 - x1 ))
    local rect_h=$(( y2 - y1 ))
    
    # Convert time values
    local start_seconds duration_seconds
    start_seconds=$(time_to_seconds "$at" "$fps")
    duration_seconds=$(time_to_seconds "$duration" "$fps")
    
    # Calculate fade durations
    local fade_in_duration fade_out_duration
    fade_in_duration=$(get_fade_duration "$appear")
    fade_out_duration=$(get_fade_duration "$disappear")
    
    info "Start: ${start_seconds}s, Duration: ${duration_seconds}s"
    
    # Build drawtext filter
    local drawtext_opts="text='${text}'"
    drawtext_opts+=":fontsize=${size}"
    drawtext_opts+=":fontcolor=${color}"
    
    # Font
    if [[ -n "$font" ]]; then
        drawtext_opts+=":font='${font}'"
    fi
    
    # Style
    if [[ "$bold" == "true" ]]; then
        drawtext_opts+=":fontcolor_expr=${color}@1|bold"
    fi
    if [[ "$italic" == "true" ]]; then
        drawtext_opts+=":fontcolor_expr=${color}@1|italic"
    fi
    
    # Position - center in rectangle
    local text_x text_y
    text_x=$(( x1 + rect_w / 2 ))
    text_y=$(( y1 + rect_h / 2 ))
    drawtext_opts+=":x=(w-text_w)/2:y=(h-text_h)/2"
    
    # Text box / background
    if [[ -n "$bg_color" ]]; then
        drawtext_opts+=":box=1:boxcolor=${bg_color}@0.8:boxborderw=${bg_padding}"
    fi
    
    # Outline
    if [[ -n "$outline" ]]; then
        IFS=':' read -r outline_width outline_color <<< "$outline"
        drawtext_opts+=":borderw=${outline_width}:bordercolor=${outline_color:-black}"
    fi
    
    # Shadow
    if [[ -n "$shadow" ]]; then
        IFS=':' read -r shadow_x shadow_y shadow_color <<< "$shadow"
        drawtext_opts+=":shadowx=${shadow_x}:shadowy=${shadow_y}:shadowcolor=${shadow_color:-black}"
    fi
    
    # Time enable
    local end_seconds
    end_seconds=$(echo "$start_seconds $duration_seconds" | awk '{printf "%.6f", $1 + $2}')
    drawtext_opts+=":enable='between(t,${start_seconds},${end_seconds})'"
    
    # Build filter chain with fade effects
    local filters="[0:v]drawtext=${drawtext_opts}[out]"
    
    # Execute ffmpeg
    info "Processing..."
    
    local ffmpeg_cmd=(
        ffmpeg -y
        -i "$input"
        -vf "$filters"
        -map "[out]"
        -map "0:a?"
        -c:a copy
        "$output"
    )
    
    if [[ "$AUTO_YES" == "true" ]]; then
        "${ffmpeg_cmd[@]}" 2>&1 | tail -5
    else
        "${ffmpeg_cmd[@]}"
    fi
    
    if [[ $? -eq 0 ]]; then
        success "Created: $output"
    else
        error "Failed to process video"
        exit 1
    fi
}

# ============================================================================
# stats Command
# ============================================================================

cmd_stats() {
    local input=""
    local json_output=false
    local short_output=false

    # Check for help first
    for arg in "$@"; do
        if [[ "$arg" == "-h" || "$arg" == "--help" ]]; then
            show_stats_help
            exit 0
        fi
    done
    
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --json)
                json_output=true
                shift
                ;;
            --short)
                short_output=true
                shift
                ;;
            -*)
                error "Unknown option: $1"
                show_stats_help
                exit 1
                ;;
            *)
                if [[ -z "$input" ]]; then
                    input="$1"
                else
                    error "Unexpected argument: $1"
                    exit 1
                fi
                shift
                ;;
        esac
    done
    
    # Validate input
    if [[ -z "$input" ]]; then
        error "Missing required argument: INPUT file"
        echo ""
        show_stats_help
        exit 1
    fi
    
    [[ ! -f "$input" ]] && error "File not found: $input" && exit 1
    
    # Get file size
    local file_size
    if [[ "$(uname)" == "Darwin" ]]; then
        file_size=$(stat -f%z "$input" 2>/dev/null || echo "unknown")
    else
        file_size=$(stat -c%s "$input" 2>/dev/null || echo "unknown")
    fi
    
    # Format file size
    local size_human
    if [[ "$file_size" != "unknown" ]]; then
        size_human=$(numfmt --to=iec-i --suffix=B "$file_size" 2>/dev/null || echo "${file_size} bytes")
    else
        size_human="unknown"
    fi
    
    # Check if it's a video or image
    local media_type
    media_type=$(ffprobe -v quiet -show_entries format=format_name \
        -of csv=p=0 "$input" 2>/dev/null | head -1)
    
    # Check for image formats
    if [[ "$input" =~ \.(jpg|jpeg|png|gif|bmp|tiff|webp)$ ]]; then
        media_type="image"
    fi
    
    if [[ "$json_output" == "true" ]]; then
        # JSON output
        local width height fps duration codec format_name pixel_format bitrate
        width=$(get_video_width "$input" 2>/dev/null || echo "N/A")
        height=$(get_video_height "$input" 2>/dev/null || echo "N/A")
        fps=$(get_video_fps "$input" 2>/dev/null || echo "N/A")
        duration=$(get_duration "$input" 2>/dev/null || echo "N/A")
        codec=$(ffprobe -v quiet -select_streams v:0 -show_entries stream=codec_name -of csv=p=0 "$input" 2>/dev/null | tr -d '"' || echo "N/A")
        format_name=$(ffprobe -v quiet -show_entries format=format_name -of csv=p=0 "$input" 2>/dev/null | tr -d '"' || echo "N/A")
        pixel_format=$(ffprobe -v quiet -select_streams v:0 -show_entries stream=pix_fmt -of csv=p=0 "$input" 2>/dev/null | tr -d '"' || echo "N/A")
        bitrate=$(ffprobe -v quiet -show_entries format=bit_rate -of csv=p=0 "$input" 2>/dev/null || echo "N/A")
        
        cat << EOF
{
  "file": "$input",
  "size": "$file_size",
  "size_human": "$size_human",
  "format": "$format_name",
  "codec": "$codec",
  "width": "$width",
  "height": "$height",
  "fps": "$fps",
  "duration": "$duration",
  "pixel_format": "$pixel_format",
  "bitrate": "$bitrate"
}
EOF
    else
        # Table output
        echo ""
        echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "${BLUE} File Statistics${NC}"
        echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e " ${GREEN}File:${NC}         $input"
        echo -e " ${GREEN}Size:${NC}         $size_human ($file_size bytes)"
        
        # Get format info
        local format_name
        format_name=$(ffprobe -v quiet -show_entries format=format_name -of csv=p=0 "$input" 2>/dev/null | tr -d '"' || echo "N/A")
        echo -e " ${GREEN}Format:${NC}       $format_name"
        
        # Video stream info
        local codec width height fps duration pixel_format bitrate frames
        codec=$(ffprobe -v quiet -select_streams v:0 -show_entries stream=codec_name -of csv=p=0 "$input" 2>/dev/null || echo "N/A")
        width=$(get_video_width "$input" 2>/dev/null || echo "N/A")
        height=$(get_video_height "$input" 2>/dev/null || echo "N/A")
        fps=$(get_video_fps "$input" 2>/dev/null || echo "N/A")
        duration=$(get_duration "$input" 2>/dev/null || echo "N/A")
        pixel_format=$(ffprobe -v quiet -select_streams v:0 -show_entries stream=pix_fmt -of csv=p=0 "$input" 2>/dev/null || echo "N/A")
        bitrate=$(ffprobe -v quiet -show_entries format=bit_rate -of csv=p=0 "$input" 2>/dev/null || echo "N/A")
        frames=$(ffprobe -v quiet -select_streams v:0 -show_entries stream=nb_frames -of csv=p=0 "$input" 2>/dev/null || echo "N/A")
        
        if [[ "$codec" != "N/A" ]]; then
            echo -e " ${GREEN}Video Codec:${NC}  $codec"
            echo -e " ${GREEN}Resolution:${NC}  ${width} × ${height}"
            echo -e " ${GREEN}Frame Rate:${NC}  $fps fps"
            echo -e " ${GREEN}Pixel Fmt:${NC}   $pixel_format"
        fi
        
        if [[ "$duration" != "N/A" ]]; then
            # Convert seconds to HH:MM:SS
            local hours minutes seconds
            hours=$(echo "$duration" | awk '{printf "%02d", int($1/3600)}')
            minutes=$(echo "$duration" | awk '{printf "%02d", int($1/60)%60}')
            seconds=$(echo "$duration" | awk '{printf "%06.3f", $1%60}')
            echo -e " ${GREEN}Duration:${NC}     ${hours}:${minutes}:${seconds} ($duration s)"
        fi
        
        if [[ "$frames" != "N/A" ]]; then
            echo -e " ${GREEN}Frames:${NC}       $frames"
        fi
        
        if [[ "$bitrate" != "N/A" && "$bitrate" != "N/A" ]]; then
            local bitrate_kbps
            bitrate_kbps=$(echo "$bitrate" | awk '{printf "%.0f", $1/1000}')
            echo -e " ${GREEN}Bitrate:${NC}      ${bitrate_kbps} kbps"
        fi
        
        # Audio stream info
        local audio_codec audio_sample_rate audio_channels
        audio_codec=$(ffprobe -v quiet -select_streams a:0 -show_entries stream=codec_name -of csv=p=0 "$input" 2>/dev/null || echo "")
        
        if [[ -n "$audio_codec" && "$audio_codec" != "N/A" ]]; then
            audio_sample_rate=$(ffprobe -v quiet -select_streams a:0 -show_entries stream=sample_rate -of csv=p=0 "$input" 2>/dev/null || echo "N/A")
            audio_channels=$(ffprobe -v quiet -select_streams a:0 -show_entries stream=channels -of csv=p=0 "$input" 2>/dev/null || echo "N/A")
            
            echo -e " ${GREEN}Audio Codec:${NC}  $audio_codec"
            echo -e " ${GREEN}Sample Rate:${NC} ${audio_sample_rate} Hz"
            echo -e " ${GREEN}Channels:${NC}    $audio_channels"
        fi
        
        echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo ""
    fi
}

# ============================================================================
# Main
# ============================================================================

main() {
    # Check for no arguments
    if [[ $# -eq 0 ]]; then
        show_help
        exit 0
    fi
    
    # Parse global options
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                show_help
                exit 0
                ;;
            -y|--yes)
                AUTO_YES=true
                shift
                ;;
            -v|--version)
                echo "edit version $VERSION"
                exit 0
                ;;
            *)
                break
                ;;
        esac
    done
    
    # Check dependencies
    check_dependencies
    
    # Parse command
    local command="$1"
    shift
    
    case "$command" in
        pic|picture|image)
            cmd_insert_picture "$@"
            ;;
        text)
            cmd_insert_text "$@"
            ;;
        stat|stats)
            cmd_stats "$@"
            ;;
        *)
            error "Unknown command: $command"
            echo ""
            echo "Available commands: pic, text, stat"
            echo "Run 'edit --help' for more information."
            exit 1
            ;;
    esac
}

main "$@"

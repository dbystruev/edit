# ============================================================================
# Coordinate Parsing
# ============================================================================

parse_coord() {
    local coord="$1"
    local total="$2"
    
    if [[ "$coord" =~ ^([0-9]+\.?[0-9]*)%$ ]]; then
        local pct="${BASH_REMATCH[1]}"
        echo "$pct" | awk -v total="$total" '{printf "%.0f", $1/100*total}'
        return 0
    fi
    
    if [[ "$coord" =~ ^[0-9]+\.?[0-9]*$ ]]; then
        echo "$coord"
        return 0
    fi
    
    error "Invalid coordinate: $coord (use pixels or percentage)"
    return 1
}

parse_rect() {
    local rect_str="$1"
    local video_width="$2"
    local video_height="$3"
    
    local corners
    IFS=' ' read -ra corners <<< "$rect_str"
    
    if [[ ${#corners[@]} -ne 2 ]]; then
        error "Rectangle requires two corners: X1,Y1 X2,Y2"
        return 1
    fi
    
    IFS=',' read -r x1 y1 <<< "${corners[0]}"
    IFS=',' read -r x2 y2 <<< "${corners[1]}"
    
    x1=$(parse_coord "$x1" "$video_width") || return 1
    y1=$(parse_coord "$y1" "$video_height") || return 1
    x2=$(parse_coord "$x2" "$video_width") || return 1
    y2=$(parse_coord "$y2" "$video_height") || return 1
    
    local min_x=$(( x1 < x2 ? x1 : x2 ))
    local min_y=$(( y1 < y2 ? y1 : y2 ))
    local max_x=$(( x1 > x2 ? x1 : x2 ))
    local max_y=$(( y1 > y2 ? y1 : y2 ))
    
    echo "$min_x $min_y $max_x $max_y $(( max_x - min_x )) $(( max_y - min_y ))"
}

# ============================================================================
# Time/Frame Parsing
# ============================================================================

time_to_seconds() {
    local time_str="$1"
    local fps="${2:-}"
    
    # Handle negative values
    local abs_time="$time_str"
    [[ "$time_str" =~ ^- ]] && abs_time="${time_str#-}"
    
    local seconds=0
    
    # Internal format
    if [[ "$abs_time" =~ ^seconds:([0-9]+\.?[0-9]*)$ ]]; then
        seconds="${BASH_REMATCH[1]}"
    # Internal frame format
    elif [[ "$abs_time" =~ ^frame:([0-9]+\.?[0-9]*)$ ]]; then
        [[ -n "$fps" ]] && seconds=$(echo "${BASH_REMATCH[1]}" | awk -v fps="$fps" '{printf "%.6f", $1/fps}') || seconds="${BASH_REMATCH[1]}"
    # Frame number (f prefix)
    elif [[ "$abs_time" =~ ^f([0-9]+\.?[0-9]*)$ ]]; then
        [[ -n "$fps" ]] && seconds=$(echo "${BASH_REMATCH[1]}" | awk -v fps="$fps" '{printf "%.6f", $1/fps}') || seconds="${BASH_REMATCH[1]}"
    # Hours:Minutes:Seconds
    elif [[ "$abs_time" =~ ^([0-9]+):([0-9]+):([0-9]+\.?[0-9]*)$ ]]; then
        seconds=$(echo "${BASH_REMATCH[1]} ${BASH_REMATCH[2]} ${BASH_REMATCH[3]}" | awk '{printf "%.6f", $1*3600 + $2*60 + $3}')
    # Minutes:Seconds
    elif [[ "$abs_time" =~ ^([0-9]+):([0-9]+\.?[0-9]*)$ ]]; then
        seconds=$(echo "${BASH_REMATCH[1]} ${BASH_REMATCH[2]}" | awk '{printf "%.6f", $1*60 + $2}')
    # Plain seconds
    elif [[ "$abs_time" =~ ^[0-9]+\.?[0-9]*$ ]]; then
        seconds="$abs_time"
    else
        error "Invalid time: $time_str"
        return 1
    fi
    
    echo "$seconds"
}

parse_time() {
    local time_str="$1"
    # Already in internal format
    [[ "$time_str" =~ ^(seconds:|frame:) ]] && echo "$time_str" && return 0
    # Frame number (f prefix)
    [[ "$time_str" =~ ^f([0-9]+\.?[0-9]*)$ ]] && echo "frame:${BASH_REMATCH[1]}" && return 0
    # Convert to seconds
    local seconds
    seconds=$(time_to_seconds "$time_str") || return 1
    echo "seconds:$seconds"
}

parse_opacity() {
    local opacity_str="$1"
    [[ "$opacity_str" =~ ^([0-9]+\.?[0-9]*)%$ ]] && echo "${BASH_REMATCH[1]}" | awk '{printf "%.2f", $1/100}' && return 0
    [[ "$opacity_str" =~ ^[0-9]+\.?[0-9]*$ ]] && echo "$opacity_str" && return 0
    error "Invalid opacity: $opacity_str"
    return 1
}

# ============================================================================
# Video Info Helpers
# ============================================================================

get_video_info() {
    ffprobe -v quiet -select_streams v:0 -show_entries "stream=$2" -of csv=p=0 "$1" 2>/dev/null
}

get_video_width() { get_video_info "$1" "width"; }
get_video_height() { get_video_info "$1" "height"; }
get_duration() { ffprobe -v quiet -show_entries format=duration -of csv=p=0 "$1" 2>/dev/null; }

get_video_fps() {
    local fps_str
    fps_str=$(get_video_info "$1" "r_frame_rate")
    [[ "$fps_str" =~ ^([0-9]+)/([0-9]+)$ ]] && echo "${BASH_REMATCH[1]} ${BASH_REMATCH[2]}" | awk '{printf "%.6f", $1/$2}' || echo "$fps_str"
}

load_params_file() {
    local file="$1"
    local -n result_array=$2
    [[ ! -f "$file" ]] && error "File not found: $file" && return 1
    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ -z "$line" || "$line" =~ ^# ]] && continue
        line=$(echo "$line" | xargs)
        for word in $line; do result_array+=("$word"); done
    done < "$file"
}

# ============================================================================
# pic Command
# ============================================================================

cmd_pic() {
    local input="" output="" param_file=""
    local pictures=() pic_ats=() pic_durations=() pic_rects=() pic_audio=()
    local pic_explicit_duration=()  # Track which pictures have explicit duration
    local global_mode="aspect-fit" global_opacity="1.0" global_audio="0"
    local at="seconds:0" duration="seconds:3" rect="" audio_mix="0"

    for arg in "$@"; do [[ "$arg" == "-h" || "$arg" == "--help" ]] && show_pic_help && exit 0; done

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -v|--verbose) VERBOSE=true; shift ;;
            --at)
                at=$(parse_time "$2") || exit 1
                # Update last picture's at if it exists
                [[ ${#pictures[@]} -gt 0 ]] && pic_ats[$((${#pictures[@]}-1))]="$at"
                shift 2 ;;
            --duration)
                duration=$(parse_time "$2") || exit 1
                if [[ ${#pictures[@]} -gt 0 ]]; then
                    pic_durations[$((${#pictures[@]}-1))]="$duration"
                    pic_explicit_duration[$((${#pictures[@]}-1))]="true"
                fi
                shift 2 ;;
            --rect)
                rect="$2 $3"
                [[ ${#pictures[@]} -gt 0 ]] && pic_rects[$((${#pictures[@]}-1))]="$rect"
                shift 3 ;;
            --mode) global_mode="$2"; shift 2 ;;
            --opacity)
                global_opacity=$(parse_opacity "$2") || exit 1
                shift 2 ;;
            --audio)
                audio_mix=$(parse_opacity "$2") || exit 1
                [[ ${#pictures[@]} -gt 0 ]] && pic_audio[$((${#pictures[@]}-1))]="$audio_mix"
                shift 2 ;;
            --file) param_file="$2"; shift 2 ;;
            -*) error "Unknown: $1"; exit 1 ;;
            *)
                # First two non-option args are input and output
                if [[ -z "$input" ]]; then
                    input="$1"
                elif [[ -z "$output" ]]; then
                    output="$1"
                else
                    # Everything else is overlay media (image or video)
                    pictures+=("$1")
                    pic_ats+=("$at")
                    pic_durations+=("$duration")
                    pic_rects+=("$rect")
                    pic_audio+=("$audio_mix")
                fi
                shift ;;
        esac
    done

    [[ -z "$input" ]] && error "Missing INPUT" && exit 1
    [[ -z "$output" ]] && error "Missing OUTPUT" && exit 1
    [[ ${#pictures[@]} -eq 0 ]] && error "Missing PICTURE or VIDEO" && exit 1
    for i in "${!pictures[@]}"; do [[ -z "${pic_rects[$i]}" ]] && error "Missing --rect for ${pictures[$i]}" && exit 1; done
    [[ ! -f "$input" ]] && error "Not found: $input" && exit 1
    for pic in "${pictures[@]}"; do [[ ! -f "$pic" ]] && error "Not found: $pic" && exit 1; done

    local vid_width vid_height fps
    vid_width=$(get_video_width "$input") || exit 1
    vid_height=$(get_video_height "$input") || exit 1
    fps=$(get_video_fps "$input")

    local input_args=(-i "$input")
    for pic in "${pictures[@]}"; do input_args+=(-i "$pic"); done

    local filters="" last_label="[0:v]" input_idx=1
    local has_video_overlay=false has_audio_mix=false
    
    for i in "${!pictures[@]}"; do
        local coords start_s end_s
        coords=$(parse_rect "${pic_rects[$i]}" "$vid_width" "$vid_height") || exit 1
        local x1 y1 _ _ rect_w rect_h
        read -r x1 y1 _ _ rect_w rect_h <<< "$coords"
        start_s=$(time_to_seconds "${pic_ats[$i]}" "$fps")
        end_s=$(echo "$start_s $(time_to_seconds "${pic_durations[$i]}" "$fps")" | awk '{printf "%.6f", $1+$2}')
        local dur_s=$(time_to_seconds "${pic_durations[$i]}" "$fps")

        info "${pictures[$i]}: at=${start_s}s, rect=${x1},${y1} (${rect_w}x${rect_h})"

        # Check if this is a video or image
        if [[ "${pictures[$i]}" =~ \.(mp4|mov|avi|mkv|webm|flv|wmv|m4v)$ ]]; then
            # Video overlay - use video's actual duration if no explicit duration given
            has_video_overlay=true
            
            # Get overlay video duration
            local overlay_dur
            overlay_dur=$(get_duration "${pictures[$i]}")
            
            # Use video duration only if user didn't specify duration for this picture
            if [[ "${pic_explicit_duration[$i]}" != "true" ]]; then
                dur_s="$overlay_dur"
                end_s=$(echo "$start_s $dur_s" | awk '{printf "%.6f", $1+$2}')
                info "Using video duration: ${dur_s}s"
            fi
            
            # Scale and trim the overlay video
            filters+="[${input_idx}:v]scale=${rect_w}:${rect_h}:force_original_aspect_ratio=decrease,pad=${rect_w}:${rect_h}:(ow-iw)/2:(oh-ih)/2:color=black@0,format=rgba,"
            filters+="trim=start=0:end=${dur_s},setpts=PTS-STARTPTS[ovr${i}];"
            
            [[ "$global_opacity" != "1.0" ]] && filters+="[ovr${i}]colorchannelmixer=aa=${global_opacity}[ovr${i}];"
            
            # Overlay video
            filters+="${last_label}[ovr${i}]overlay=${x1}:${y1}:enable='between(t\\,${start_s}\\,${end_s})'[v${input_idx}];"
            
            # Handle audio mixing for video overlay (only if overlay has audio and audio_vol > 0)
            local audio_vol="${pic_audio[$i]}"
            local overlay_has_audio=false
            ffprobe -v quiet -select_streams a:0 -show_entries stream=codec_name -of csv=p=0 "${pictures[$i]}" 2>/dev/null | grep -q . && overlay_has_audio=true
            
            if [[ "$audio_vol" != "0" && "$overlay_has_audio" == "true" ]]; then
                filters+="[${input_idx}:a]atrim=start=0:end=${dur_s},asetpts=PTS-STARTPTS,volume=${audio_vol}[ovr_a];"
                filters+="[0:a]volume=1.0[main_a];"
                filters+="[main_a][ovr_a]amix=inputs=2:duration=first:dropout_transition=0[aout];"
                has_audio_mix=true
            fi
        else
            # Image overlay - existing behavior
            filters+="[${input_idx}:v]scale=${rect_w}:${rect_h}:force_original_aspect_ratio=decrease,pad=${rect_w}:${rect_h}:(ow-iw)/2:(oh-ih)/2:color=black@0,format=rgba[ovr${i}];"
            [[ "$global_opacity" != "1.0" ]] && filters+="[ovr${i}]colorchannelmixer=aa=${global_opacity}[ovr${i}];"
            filters+="${last_label}[ovr${i}]overlay=${x1}:${y1}:enable='between(t\\,${start_s}\\,${end_s})'[v${input_idx}];"
        fi
        
        last_label="[v${input_idx}]"
        input_idx=$((input_idx + 1))
    done
    filters="${filters%;}"

    local loglevel="warning"
    [[ "$VERBOSE" == "true" ]] && loglevel="info"

    # Build output mapping
    local map_args=(-map "$last_label")
    if [[ "$has_audio_mix" == "true" ]]; then
        # Use mixed audio if video overlay has audio and audio_mix > 0
        map_args+=(-map "[aout]" -c:a aac)
    else
        map_args+=(-map "0:a?" -c:a copy)
    fi

    ffmpeg -y -loglevel "$loglevel" "${input_args[@]}" -filter_complex "$filters" "${map_args[@]}" -stats "$output" && success "Created: $output" || error "Failed"
}

# ============================================================================
# text Command (with ImageMagick fallback)
# ============================================================================

cmd_text() {
    local input="" output=""
    local texts=() text_ats=() text_durations=() text_rects=()
    local text_colors=() text_sizes=() text_fonts=() text_bolds=() text_outlines=() text_bg_colors=()
    local at="seconds:0" duration="seconds:3" rect=""
    local color="white" size="384" font="" bold=false outline="" bg_color=""

    for arg in "$@"; do [[ "$arg" == "-h" || "$arg" == "--help" ]] && show_text_help && exit 0; done

    local has_drawtext=false has_magick=false magick_cmd=""
    ffmpeg -filters 2>/dev/null | grep -q drawtext && has_drawtext=true
    
    for cmd in convert magick; do
        if command -v "$cmd" &>/dev/null; then has_magick=true; magick_cmd="$cmd"; break; fi
        for path in /opt/homebrew/bin /usr/local/bin; do
            if [[ -x "$path/$cmd" ]]; then has_magick=true; magick_cmd="$path/$cmd"; break 2; fi
        done
    done

    if [[ "$has_drawtext" == "false" && "$has_magick" == "false" ]]; then
        error "Need ffmpeg drawtext or ImageMagick. Install: brew install imagemagick"; exit 1
    fi

    # Parse arguments - support multiple texts like pic supports multiple images
    # Pattern: text1 --at 48 --rect ... text2 --at 28 ...
    # --at/--rect etc. update the PRECEDING text, not the following one
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -v|--verbose) VERBOSE=true; shift ;;
            --at)
                local new_at=$(parse_time "$2") || exit 1
                if [[ ${#texts[@]} -gt 0 ]]; then
                    text_ats[$((${#texts[@]}-1))]="$new_at"
                else
                    at="$new_at"
                fi
                shift 2 ;;
            --duration)
                local new_dur=$(parse_time "$2") || exit 1
                if [[ ${#texts[@]} -gt 0 ]]; then
                    text_durations[$((${#texts[@]}-1))]="$new_dur"
                else
                    duration="$new_dur"
                fi
                shift 2 ;;
            --rect)
                local new_rect="$2 $3"
                if [[ ${#texts[@]} -gt 0 ]]; then
                    text_rects[$((${#texts[@]}-1))]="$new_rect"
                else
                    rect="$new_rect"
                fi
                shift 3 ;;
            --color)
                if [[ ${#texts[@]} -gt 0 ]]; then
                    text_colors[$((${#texts[@]}-1))]="$2"
                else
                    color="$2"
                fi
                shift 2 ;;
            --size)
                if [[ ${#texts[@]} -gt 0 ]]; then
                    text_sizes[$((${#texts[@]}-1))]="$2"
                else
                    size="$2"
                fi
                shift 2 ;;
            --font)
                if [[ ${#texts[@]} -gt 0 ]]; then
                    text_fonts[$((${#texts[@]}-1))]="$2"
                else
                    font="$2"
                fi
                shift 2 ;;
            --bold)
                if [[ ${#texts[@]} -gt 0 ]]; then
                    text_bolds[$((${#texts[@]}-1))]="true"
                else
                    bold=true
                fi
                shift ;;
            --outline)
                if [[ ${#texts[@]} -gt 0 ]]; then
                    text_outlines[$((${#texts[@]}-1))]="$2"
                else
                    outline="$2"
                fi
                shift 2 ;;
            --bg-color)
                if [[ ${#texts[@]} -gt 0 ]]; then
                    text_bg_colors[$((${#texts[@]}-1))]="$2"
                else
                    bg_color="$2"
                fi
                shift 2 ;;
            -*) error "Unknown: $1"; exit 1 ;;
            *)
                if [[ -z "$input" ]]; then
                    input="$1"
                elif [[ -z "$output" ]]; then
                    output="$1"
                else
                    # Inherit from previous text if exists
                    local prev=$((${#texts[@]}-1))
                    if [[ $prev -ge 0 ]]; then
                        # Use previous text's values as defaults for new text
                        at="${text_ats[$prev]}"
                        duration="${text_durations[$prev]}"
                        rect="${text_rects[$prev]}"
                        color="${text_colors[$prev]}"
                        size="${text_sizes[$prev]}"
                        font="${text_fonts[$prev]}"
                        bold="${text_bolds[$prev]}"
                        outline="${text_outlines[$prev]}"
                        bg_color="${text_bg_colors[$prev]}"
                    fi
                    texts+=("$1")
                    text_ats+=("$at")
                    text_durations+=("$duration")
                    text_rects+=("$rect")
                    text_colors+=("$color")
                    text_sizes+=("$size")
                    text_fonts+=("$font")
                    text_bolds+=("$bold")
                    text_outlines+=("$outline")
                    text_bg_colors+=("$bg_color")
                fi
                shift ;;
        esac
    done

    [[ -z "$input" ]] && error "Missing INPUT" && exit 1
    [[ -z "$output" ]] && error "Missing OUTPUT" && exit 1
    [[ ${#texts[@]} -eq 0 ]] && error "Missing TEXT" && exit 1
    for i in "${!texts[@]}"; do [[ -z "${text_rects[$i]}" ]] && error "Missing --rect for '${texts[$i]}'" && exit 1; done
    [[ ! -f "$input" ]] && error "Not found: $input" && exit 1

    # Sort texts by --at time (selection sort)
    local n=${#texts[@]}
    info "Before sort: $(for i in "${!texts[@]}"; do echo -n "${texts[$i]}=${text_ats[$i]} "; done)"
    
    for ((i=0; i<n-1; i++)); do
        local min_idx=$i
        local min_val="${text_ats[$i]#seconds:}"
        min_val="${min_val#frame:}"
        for ((j=i+1; j<n; j++)); do
            local cur_val="${text_ats[$j]#seconds:}"
            cur_val="${cur_val#frame:}"
            if [[ "$cur_val" -lt "$min_val" ]] 2>/dev/null; then
                min_idx=$j
                min_val="$cur_val"
            fi
        done
        if [[ $min_idx -ne $i ]]; then
            local tmp="${texts[$i]}"; texts[$i]="${texts[$min_idx]}"; texts[$min_idx]="$tmp"
            tmp="${text_ats[$i]}"; text_ats[$i]="${text_ats[$min_idx]}"; text_ats[$min_idx]="$tmp"
            tmp="${text_durations[$i]}"; text_durations[$i]="${text_durations[$min_idx]}"; text_durations[$min_idx]="$tmp"
            tmp="${text_rects[$i]}"; text_rects[$i]="${text_rects[$min_idx]}"; text_rects[$min_idx]="$tmp"
            tmp="${text_colors[$i]}"; text_colors[$i]="${text_colors[$min_idx]}"; text_colors[$min_idx]="$tmp"
            tmp="${text_sizes[$i]}"; text_sizes[$i]="${text_sizes[$min_idx]}"; text_sizes[$min_idx]="$tmp"
            tmp="${text_fonts[$i]}"; text_fonts[$i]="${text_fonts[$min_idx]}"; text_fonts[$min_idx]="$tmp"
            tmp="${text_bolds[$i]}"; text_bolds[$i]="${text_bolds[$min_idx]}"; text_bolds[$min_idx]="$tmp"
            tmp="${text_outlines[$i]}"; text_outlines[$i]="${text_outlines[$min_idx]}"; text_outlines[$min_idx]="$tmp"
            tmp="${text_bg_colors[$i]}"; text_bg_colors[$i]="${text_bg_colors[$min_idx]}"; text_bg_colors[$min_idx]="$tmp"
            info "Swapped $i <-> $min_idx"
        fi
    done
    
    info "After sort: $(for i in "${!texts[@]}"; do echo -n "${texts[$i]}=${text_ats[$i]} "; done)"

    local width height fps
    width=$(get_video_width "$input") || exit 1
    height=$(get_video_height "$input") || exit 1
    fps=$(get_video_fps "$input")

    # Create temp images for each text
    local tmp_images=()
    local tmp_dir="/tmp/edit_text_$$"
    mkdir -p "$tmp_dir"

    # Find usable font
    local use_font=""
    if [[ -n "$font" ]]; then
        use_font="$font"
    else
        for f in "/Library/Fonts/Arial Unicode.ttf" "/System/Library/Fonts/Supplemental/Arial.ttf" \
                 "/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf" "/usr/share/fonts/TTF/DejaVuSans.ttf"; do
            [[ -f "$f" ]] && use_font="$f" && break
        done
    fi

    for i in "${!texts[@]}"; do
        local txt="${texts[$i]}"
        local txt_color="${text_colors[$i]}"
        local txt_size="${text_sizes[$i]}"
        local txt_rect="${text_rects[$i]}"
        local txt_bold="${text_bolds[$i]}"
        local txt_font="${text_fonts[$i]}"
        [[ -n "$txt_font" ]] && use_font="$txt_font"

        local coords txt_w txt_h
        coords=$(parse_rect "$txt_rect" "$width" "$height") || exit 1
        local _ _ _ _ 
        read -r _ _ _ _ txt_w txt_h <<< "$coords"

        local tmp_img="${tmp_dir}/text_${i}.png"
        tmp_images+=("$tmp_img")

        if [[ "$has_drawtext" == "false" ]]; then
            # Create text image with proper word wrapping and centering
            # Manual word wrap at spaces, then center in canvas
            
            local font_name="sans"
            [[ -n "$use_font" ]] && font_name="$use_font"
            
            # Word wrap: conservative estimate, break at spaces
            # Each CJK char is ~1.0 * font_size, Latin ~0.5 * font_size
            # Use safe estimate: each char ~0.8 * font_size pixels wide
            local char_width=$(( txt_size * 8 / 10 ))
            [[ $char_width -lt 1 ]] && char_width=1
            local max_chars=$(( txt_w * 9 / 10 / char_width ))
            [[ $max_chars -lt 3 ]] && max_chars=3
            
            local wrapped=""
            local line=""
            for word in $txt; do
                if [[ ${#line} -gt 0 && $((${#line} + ${#word} + 1)) -gt $max_chars ]]; then
                    [[ -n "$wrapped" ]] && wrapped="${wrapped}\n"
                    wrapped="${wrapped}${line}"
                    line="$word"
                else
                    [[ -n "$line" ]] && line="$line "
                    line="${line}${word}"
                fi
            done
            [[ -n "$line" ]] && { [[ -n "$wrapped" ]] && wrapped="${wrapped}\n"; wrapped="${wrapped}${line}"; }
            
            # Count lines to determine canvas height
            local num_lines=1
            [[ -n "$wrapped" ]] && num_lines=$(echo -e "$wrapped" | wc -l)
            local canvas_h=$(( num_lines * txt_size * 14 / 10 ))
            
            # Make canvas wider to allow text overflow (2x width)
            local canvas_w=$(( txt_w * 2 ))
            
            # Create text image with proper alpha channel
            local font_flag=""
            [[ -n "$use_font" ]] && font_flag="-font '${use_font}'"
            
            # Create text on black background, make black transparent, output as PNG32
            # Canvas is wider than rectangle to allow text overflow
            # Add thick black border around text for visibility
            local border_width=$(( txt_size / 16 ))
            [[ $border_width -lt 2 ]] && border_width=2
            
            # Create text with border: draw black text first (offset), then white text on top
            eval $magick_cmd \
                -size "${canvas_w}x${canvas_h}" xc:black \
                ${font_flag} \
                -pointsize ${txt_size} \
                -fill black \
                -stroke black -strokewidth ${border_width} \
                -gravity center \
                -annotate +0+0 "'$(echo -e "$wrapped")'" \
                -fill white \
                -stroke none \
                -annotate +0+0 "'$(echo -e "$wrapped")'" \
                -fuzz 10% \
                -transparent black \
                PNG32:"'${tmp_img}'" 2>/dev/null
            
            [[ ! -f "$tmp_img" ]] && error "Failed to create text image $i" && exit 1
            local img_size=$($magick_cmd identify -format "%wx%h" "$tmp_img" 2>/dev/null || echo "?")
            info "Created text $i: '$txt' (${img_size}, size=${txt_size})"
        fi
    done

    # Build cmd_pic arguments - pass all images with their parameters
    # Each image needs its own --at to override inherited values
    local pic_args=("$input" "$output")
    for i in "${!texts[@]}"; do
        local txt_at="${text_ats[$i]}"
        local txt_dur="${text_durations[$i]}"
        local txt_rect="${text_rects[$i]}"
        local rect_p1 rect_p2
        read -r rect_p1 rect_p2 <<< "$txt_rect"
        
        # Extract raw time values
        local raw_at="$txt_at"
        [[ "$raw_at" =~ ^seconds: ]] && raw_at="${raw_at#seconds:}"
        [[ "$raw_at" =~ ^frame: ]] && raw_at="f${raw_at#frame:}"
        local raw_dur="$txt_dur"
        [[ "$raw_dur" =~ ^seconds: ]] && raw_dur="${raw_dur#seconds:}"
        [[ "$raw_dur" =~ ^frame: ]] && raw_dur="f${raw_dur#frame:}"
        
        info "Text $i: '${texts[$i]}' at=${raw_at}s"
        pic_args+=(--at "$raw_at" --duration "$raw_dur" --rect "$rect_p1" "$rect_p2" "${tmp_images[$i]}")
    done

    # Execute pic command with all images
    cmd_pic "${pic_args[@]}"
    local result=$?
    
    rm -rf "$tmp_dir"
    return $result
}

# ============================================================================
# stat Command
# ============================================================================

display_stat() {
    local input="$1" json_output="$2"
    [[ ! -f "$input" ]] && error "Not found: $input" && return 1

    local file_size
    [[ "$(uname)" == "Darwin" ]] && file_size=$(stat -f%z "$input" 2>/dev/null || echo "unknown") || file_size=$(stat -c%s "$input" 2>/dev/null || echo "unknown")
    local size_human
    [[ "$file_size" != "unknown" ]] && size_human=$(numfmt --to=iec-i --suffix=B "$file_size" 2>/dev/null || echo "${file_size} bytes") || size_human="unknown"

    local codec width height fps duration pixel_format bitrate format_name frames
    format_name=$(ffprobe -v quiet -show_entries format=format_name -of csv=p=0 "$input" 2>/dev/null | tr -d '"' || echo "N/A")
    codec=$(ffprobe -v quiet -select_streams v:0 -show_entries stream=codec_name -of csv=p=0 "$input" 2>/dev/null || echo "N/A")
    width=$(get_video_width "$input" 2>/dev/null || echo "N/A")
    height=$(get_video_height "$input" 2>/dev/null || echo "N/A")
    fps=$(get_video_fps "$input" 2>/dev/null || echo "N/A")
    duration=$(get_duration "$input" 2>/dev/null || echo "N/A")
    pixel_format=$(ffprobe -v quiet -select_streams v:0 -show_entries stream=pix_fmt -of csv=p=0 "$input" 2>/dev/null || echo "N/A")
    bitrate=$(ffprobe -v quiet -show_entries format=bit_rate -of csv=p=0 "$input" 2>/dev/null || echo "N/A")
    frames=$(ffprobe -v quiet -select_streams v:0 -show_entries stream=nb_frames -of csv=p=0 "$input" 2>/dev/null || echo "N/A")

    if [[ "$json_output" == "true" ]]; then
        cat << EOF
{"file":"$input","size":"$file_size","size_human":"$size_human","format":"$format_name","codec":"$codec","width":"$width","height":"$height","fps":"$fps","duration":"$duration","pixel_format":"$pixel_format","bitrate":"$bitrate"}
EOF
    else
        echo ""
        echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e " ${GREEN}File:${NC}         $input"
        echo -e " ${GREEN}Size:${NC}         $size_human"
        echo -e " ${GREEN}Format:${NC}       $format_name"
        [[ "$codec" != "N/A" ]] && echo -e " ${GREEN}Codec:${NC}        $codec"
        [[ "$width" != "N/A" ]] && echo -e " ${GREEN}Resolution:${NC}   ${width} × ${height}"
        [[ "$fps" != "N/A" ]] && echo -e " ${GREEN}Frame Rate:${NC}   $fps fps"
        if [[ "$duration" != "N/A" ]]; then
            local h m s
            h=$(echo "$duration" | awk '{printf "%02d", int($1/3600)}')
            m=$(echo "$duration" | awk '{printf "%02d", int($1/60)%60}')
            s=$(echo "$duration" | awk '{printf "%06.3f", $1%60}')
            echo -e " ${GREEN}Duration:${NC}     ${h}:${m}:${s}"
        fi
        [[ "$frames" != "N/A" ]] && echo -e " ${GREEN}Frames:${NC}       $frames"
        [[ "$bitrate" != "N/A" ]] && echo -e " ${GREEN}Bitrate:${NC}      $(echo "$bitrate" | awk '{printf "%.0f", $1/1000}') kbps"
        echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    fi
}

cmd_stat() {
    local files=() json_output=false
    for arg in "$@"; do [[ "$arg" == "-h" || "$arg" == "--help" ]] && show_stat_help && exit 0; done
    while [[ $# -gt 0 ]]; do
        case "$1" in --json) json_output=true; shift;; -v|--verbose) VERBOSE=true; shift;; -*) shift;; *) files+=("$1"); shift;; esac
    done
    [[ ${#files[@]} -eq 0 ]] && error "Missing FILE(s)" && exit 1
    for file in "${files[@]}"; do [[ -f "$file" ]] && display_stat "$file" "$json_output" || error "Not found: $file"; done
}

# ============================================================================
# crop Command
# ============================================================================

cmd_crop() {
    local input="" output="" from_time="" to_time=""
    for arg in "$@"; do [[ "$arg" == "-h" || "$arg" == "--help" ]] && show_crop_help && exit 0; done
    while [[ $# -gt 0 ]]; do
        case "$1" in -v|--verbose) VERBOSE=true; shift;; --from) from_time="$2"; shift 2;; --to) to_time="$2"; shift 2;; -*) error "Unknown: $1"; exit 1;; *) [[ -z "$input" ]] && input="$1" || output="$1"; shift;; esac
    done
    [[ -z "$input" || -z "$output" ]] && error "Usage: edit crop INPUT OUTPUT --from TIME --to TIME" && exit 1
    [[ ! -f "$input" ]] && error "Not found: $input" && exit 1

    # Get video info for time conversion
    local vid_duration vid_fps
    vid_duration=$(get_duration "$input")
    vid_fps=$(get_video_fps "$input")
    
    # Convert time values to seconds
    local from_sec="" to_sec=""
    [[ -n "$from_time" ]] && from_sec=$(parse_time_value "$from_time" "$vid_fps" "$vid_duration")
    [[ -n "$to_time" ]] && to_sec=$(parse_time_value "$to_time" "$vid_fps" "$vid_duration")

    local loglevel="warning"; [[ "$VERBOSE" == "true" ]] && loglevel="info"
    local cmd=(ffmpeg -y -loglevel "$loglevel")
    # Both -ss and -to must be before -i for correct behavior
    [[ -n "$from_sec" ]] && cmd+=(-ss "$from_sec")
    [[ -n "$to_sec" ]] && cmd+=(-to "$to_sec")
    cmd+=(-i "$input" -c copy -stats "$output")

    "${cmd[@]}" && success "Created: $output" || error "Failed"
}

# ============================================================================
# cut Command
# ============================================================================

# Parse time value: supports seconds, MM:SS, HH:MM:SS, fXXX (frames), negative values
# Returns seconds as float
parse_time_value() {
    local time_str="$1"
    local fps="$2"
    local duration="$3"
    
    # Handle negative values (from end of clip)
    local negative=false
    local abs_time="$time_str"
    if [[ "$time_str" =~ ^- ]]; then
        negative=true
        abs_time="${time_str#-}"
    fi
    
    local seconds=0
    
    # Frame number (fXXX)
    if [[ "$abs_time" =~ ^f([0-9]+\.?[0-9]*)$ ]]; then
        seconds=$(echo "${BASH_REMATCH[1]}" | awk -v fps="$fps" '{printf "%.6f", $1/fps}')
    # HH:MM:SS
    elif [[ "$abs_time" =~ ^([0-9]+):([0-9]+):([0-9]+\.?[0-9]*)$ ]]; then
        seconds=$(echo "${BASH_REMATCH[1]} ${BASH_REMATCH[2]} ${BASH_REMATCH[3]}" | awk '{printf "%.6f", $1*3600 + $2*60 + $3}')
    # MM:SS
    elif [[ "$abs_time" =~ ^([0-9]+):([0-9]+\.?[0-9]*)$ ]]; then
        seconds=$(echo "${BASH_REMATCH[1]} ${BASH_REMATCH[2]}" | awk '{printf "%.6f", $1*60 + $2}')
    # Plain seconds
    elif [[ "$abs_time" =~ ^[0-9]+\.?[0-9]*$ ]]; then
        seconds="$abs_time"
    else
        error "Invalid time format: $time_str"
        return 1
    fi
    
    # Convert negative values (from end of clip)
    if [[ "$negative" == "true" ]]; then
        seconds=$(echo "$duration $seconds" | awk '{printf "%.6f", $1 - $2}')
    fi
    
    echo "$seconds"
}

cmd_cut() {
    local input="" output="" from_time="" to_time=""
    for arg in "$@"; do [[ "$arg" == "-h" || "$arg" == "--help" ]] && show_cut_help && exit 0; done
    while [[ $# -gt 0 ]]; do
        case "$1" in -v|--verbose) VERBOSE=true; shift;; --from) from_time="$2"; shift 2;; --to) to_time="$2"; shift 2;; -*) error "Unknown: $1"; exit 1;; *) [[ -z "$input" ]] && input="$1" || output="$1"; shift;; esac
    done
    [[ -z "$input" || -z "$output" ]] && error "Usage: edit cut INPUT OUTPUT --from/--to TIME" && exit 1
    [[ ! -f "$input" ]] && error "Not found: $input" && exit 1
    [[ -z "$from_time" && -z "$to_time" ]] && error "Specify --from and/or --to" && exit 1

    # Get video info for time conversion
    local vid_duration vid_fps
    vid_duration=$(get_duration "$input")
    vid_fps=$(get_video_fps "$input")
    
    # Convert time values to seconds
    local from_sec="" to_sec=""
    [[ -n "$from_time" ]] && from_sec=$(parse_time_value "$from_time" "$vid_fps" "$vid_duration")
    [[ -n "$to_time" ]] && to_sec=$(parse_time_value "$to_time" "$vid_fps" "$vid_duration")
    
    local loglevel="warning"; [[ "$VERBOSE" == "true" ]] && loglevel="info"
    local filter=""
    
    if [[ -n "$from_sec" && -n "$to_sec" ]]; then
        # Cut middle section
        filter="[0:v]trim=start=0:end=${from_sec},setpts=PTS-STARTPTS[v1];[0:v]trim=start=${to_sec},setpts=PTS-STARTPTS[v2];[v1][v2]concat=n=2:v=1:a=0[vout];"
        filter+="[0:a]atrim=start=0:end=${from_sec},asetpts=PTS-STARTPTS[a1];[0:a]atrim=start=${to_sec},asetpts=PTS-STARTPTS[a2];[a1][a2]concat=n=2:v=0:a=1[aout]"
    elif [[ -n "$to_sec" ]]; then
        # Cut from start to to_time
        filter="[0:v]trim=start=${to_sec},setpts=PTS-STARTPTS[vout];[0:a]atrim=start=${to_sec},asetpts=PTS-STARTPTS[aout]"
    else
        # Cut from start to from_time
        filter="[0:v]trim=start=0:end=${from_sec},setpts=PTS-STARTPTS[vout];[0:a]atrim=start=0:end=${from_sec},asetpts=PTS-STARTPTS[aout]"
    fi

    ffmpeg -y -loglevel "$loglevel" -i "$input" -filter_complex "$filter" -map "[vout]" -map "[aout]" -stats "$output" && success "Created: $output" || error "Failed"
}

# ============================================================================
# insert Command
# ============================================================================

cmd_insert() {
    local main="" inserted="" output="" at_time="0"
    for arg in "$@"; do [[ "$arg" == "-h" || "$arg" == "--help" ]] && show_insert_help && exit 0; done
    while [[ $# -gt 0 ]]; do
        case "$1" in -v|--verbose) VERBOSE=true; shift;; --at) at_time="$2"; shift 2;; -*) error "Unknown: $1"; exit 1;; *) [[ -z "$main" ]] && main="$1" || [[ -z "$inserted" ]] && inserted="$1" || output="$1"; shift;; esac
    done
    [[ -z "$main" || -z "$inserted" || -z "$output" ]] && error "Usage: edit insert MAIN INSERTED OUTPUT --at TIME" && exit 1
    [[ ! -f "$main" || ! -f "$inserted" ]] && error "File not found" && exit 1

    # Parse time value to seconds
    local vid_duration vid_fps
    vid_duration=$(get_duration "$main")
    vid_fps=$(get_video_fps "$main")
    local at_sec
    at_sec=$(parse_time_value "$at_time" "$vid_fps" "$vid_duration")

    local loglevel="warning"; [[ "$VERBOSE" == "true" ]] && loglevel="info"
    local filter="[0:v]trim=start=0:end=${at_sec},setpts=PTS-STARTPTS[v1];[0:v]trim=start=${at_sec},setpts=PTS-STARTPTS[v2];[1:v]setpts=PTS-STARTPTS[v3];"
    filter+="[v1][v3][v2]concat=n=3:v=1:a=0[vout];"
    filter+="[0:a]atrim=start=0:end=${at_sec}[a1];[0:a]atrim=start=${at_sec}[a2];[1:a]asetpts=PTS-STARTPTS[a3];"
    filter+="[a1][a3][a2]concat=n=3:v=0:a=1[aout]"

    ffmpeg -y -loglevel "$loglevel" -i "$main" -i "$inserted" -filter_complex "$filter" -map "[vout]" -map "[aout]" -stats "$output" && success "Created: $output" || error "Failed"
}

# ============================================================================
# audio Command
# ============================================================================

cmd_audio() {
    local input="" audio_src="" output="" at_time="0" duration="" mix_level="1.0"
    for arg in "$@"; do [[ "$arg" == "-h" || "$arg" == "--help" ]] && show_audio_help && exit 0; done
    while [[ $# -gt 0 ]]; do
        case "$1" in -v|--verbose) VERBOSE=true; shift;; --at) at_time="$2"; shift 2;; --duration) duration="$2"; shift 2;; --mix) mix_level=$(parse_opacity "$2") || exit 1; shift 2;; -*) error "Unknown: $1"; exit 1;; *) [[ -z "$input" ]] && input="$1" || [[ -z "$audio_src" ]] && audio_src="$1" || output="$1"; shift;; esac
    done
    [[ -z "$input" || -z "$audio_src" || -z "$output" ]] && error "Usage: edit audio INPUT AUDIO OUTPUT --at TIME --mix LEVEL" && exit 1
    [[ ! -f "$input" || ! -f "$audio_src" ]] && error "File not found" && exit 1

    local loglevel="warning"; [[ "$VERBOSE" == "true" ]] && loglevel="info"
    local orig_w new_w
    orig_w=$(echo "1.0 $mix_level" | awk '{printf "%.2f", $1-$2}')
    new_w="$mix_level"

    local filter=""
    if [[ -n "$duration" ]]; then
        local end_t=$(echo "$at_time $duration" | awk '{printf "%.6f", $1+$2}')
        filter="[1:a]atrim=start=0:end=${duration},asetpts=PTS-STARTPTS,volume=${new_w}[new];[0:a]volume=${orig_w}[orig];"
        filter+="[orig][new]amix=inputs=2:duration=first:dropout_transition=0[mixed];"
        filter+="[0:a]atrim=start=0:end=${at_time}[b];[0:a]atrim=start=${end_t}[a];[b][mixed][a]concat=n=3:v=0:a=1[aout]"
    else
        filter="[1:a]asetpts=PTS-STARTPTS,volume=${new_w}[new];[0:a]volume=${orig_w}[orig];"
        filter+="[orig][new]amix=inputs=2:duration=first:dropout_transition=0[mixed];"
        filter+="[0:a]atrim=start=0:end=${at_time}[b];[b][mixed]concat=n=2:v=0:a=1[aout]"
    fi

    ffmpeg -y -loglevel "$loglevel" -i "$input" -i "$audio_src" -filter_complex "$filter" -map "0:v" -map "[aout]" -c:v copy -shortest -stats "$output" && success "Created: $output" || error "Failed"
}

# ============================================================================
# fade-in Command
# ============================================================================

cmd_fadein() {
    local input="" output="" duration="3" target="both"
    for arg in "$@"; do [[ "$arg" == "-h" || "$arg" == "--help" ]] && show_fadein_help && exit 0; done
    while [[ $# -gt 0 ]]; do
        case "$1" in -v|--verbose) VERBOSE=true; shift;; --duration) duration="$2"; shift 2;; --target) target="$2"; shift 2;; -*) error "Unknown: $1"; exit 1;; *) [[ -z "$input" ]] && input="$1" || output="$1"; shift;; esac
    done
    [[ -z "$input" || -z "$output" ]] && error "Usage: edit fade-in INPUT OUTPUT [--duration 3] [--target both|video|audio]" && exit 1
    [[ ! -f "$input" ]] && error "File not found: $input" && exit 1

    local loglevel="warning"; [[ "$VERBOSE" == "true" ]] && loglevel="info"
    local vfilter="" afilter=""
    [[ "$target" == "both" || "$target" == "video" ]] && vfilter="-vf fade=t=in:st=0:d=${duration}"
    [[ "$target" == "both" || "$target" == "audio" ]] && afilter="-af afade=t=in:st=0:d=${duration}"
    ffmpeg -y -loglevel "$loglevel" -i "$input" $vfilter $afilter -c:v libx264 -crf 23 -stats "$output" && success "Created: $output" || error "Failed"
}

# ============================================================================
# fade-out Command
# ============================================================================

cmd_fadeout() {
    local input="" output="" duration="3" target="both"
    for arg in "$@"; do [[ "$arg" == "-h" || "$arg" == "--help" ]] && show_fadeout_help && exit 0; done
    while [[ $# -gt 0 ]]; do
        case "$1" in -v|--verbose) VERBOSE=true; shift;; --duration) duration="$2"; shift 2;; --target) target="$2"; shift 2;; -*) error "Unknown: $1"; exit 1;; *) [[ -z "$input" ]] && input="$1" || output="$1"; shift;; esac
    done
    [[ -z "$input" || -z "$output" ]] && error "Usage: edit fade-out INPUT OUTPUT [--duration 3] [--target both|video|audio]" && exit 1
    [[ ! -f "$input" ]] && error "File not found: $input" && exit 1

    # Get video duration to calculate fade start time
    local vid_duration
    vid_duration=$(get_duration "$input")
    local fade_start
    fade_start=$(echo "$vid_duration $duration" | awk '{printf "%.6f", $1-$2}')

    local loglevel="warning"; [[ "$VERBOSE" == "true" ]] && loglevel="info"
    local vfilter="" afilter=""
    [[ "$target" == "both" || "$target" == "video" ]] && vfilter="-vf fade=t=out:st=${fade_start}:d=${duration}"
    [[ "$target" == "both" || "$target" == "audio" ]] && afilter="-af afade=t=out:st=${fade_start}:d=${duration}"
    ffmpeg -y -loglevel "$loglevel" -i "$input" $vfilter $afilter -c:v libx264 -crf 23 -stats "$output" && success "Created: $output" || error "Failed"
}

# ============================================================================
# resize Command
# ============================================================================

cmd_resize() {
    local input="" output="" tw="" th="" scale=""
    for arg in "$@"; do [[ "$arg" == "-h" || "$arg" == "--help" ]] && show_resize_help && exit 0; done
    while [[ $# -gt 0 ]]; do
        case "$1" in -v|--verbose) VERBOSE=true; shift;; --width) tw="$2"; shift 2;; --height) th="$2"; shift 2;; --scale) scale="$2"; shift 2;; -*) error "Unknown: $1"; exit 1;; *) [[ -z "$input" ]] && input="$1" || output="$1"; shift;; esac
    done
    [[ -z "$input" || -z "$output" ]] && error "Usage: edit resize INPUT OUTPUT --width/--height/--scale" && exit 1
    [[ ! -f "$input" ]] && error "Not found: $input" && exit 1
    [[ -z "$tw" && -z "$th" && -z "$scale" ]] && error "Specify --width, --height, or --scale" && exit 1

    local cw ch
    cw=$(get_video_width "$input"); ch=$(get_video_height "$input")
    if [[ -n "$scale" ]]; then
        tw=$(echo "$cw $scale" | awk '{printf "%.0f", $1*$2}')
        th=$(echo "$ch $scale" | awk '{printf "%.0f", $1*$2}')
    elif [[ -n "$tw" && -z "$th" ]]; then
        th=$(echo "$ch $tw $cw" | awk '{printf "%.0f", $1*$2/$3}')
    elif [[ -z "$tw" && -n "$th" ]]; then
        tw=$(echo "$cw $th $ch" | awk '{printf "%.0f", $1*$2/$3}')
    fi
    tw=$(( tw / 2 * 2 )); th=$(( th / 2 * 2 ))

    info "Resizing: ${cw}x${ch} -> ${tw}x${th}"
    local loglevel="warning"; [[ "$VERBOSE" == "true" ]] && loglevel="info"
    ffmpeg -y -loglevel "$loglevel" -i "$input" -vf "scale=${tw}:${th}" -c:a copy -stats "$output" && success "Created: $output" || error "Failed"
}

# ============================================================================
# dedup Command
# ============================================================================

cmd_dedup() {
    local input="" output="" threshold="1024"
    for arg in "$@"; do [[ "$arg" == "-h" || "$arg" == "--help" ]] && show_dedup_help && exit 0; done
    while [[ $# -gt 0 ]]; do
        case "$1" in -v|--verbose) VERBOSE=true; shift;; --threshold) threshold="$2"; shift 2;; -*) error "Unknown: $1"; exit 1;; *) [[ -z "$input" ]] && input="$1" || output="$1"; shift;; esac
    done
    [[ -z "$input" || -z "$output" ]] && error "Usage: edit dedup INPUT OUTPUT [--threshold 1024]" && exit 1
    [[ ! -f "$input" ]] && error "Not found: $input" && exit 1

    local loglevel="warning"; [[ "$VERBOSE" == "true" ]] && loglevel="info"
    
    # Use mpdecimate to remove duplicate frames
    # mpdecimate threshold is in terms of pixel difference sum
    # Default 1024 works well for most videos
    # -fps_mode vfr ensures dropped frames are not duplicated
    info "Removing duplicate frames (threshold: $threshold)..."
    
    ffmpeg -y -loglevel "$loglevel" -i "$input" \
        -vf "mpdecimate=hi=${threshold}:lo=${threshold}" \
        -fps_mode vfr \
        -c:v libx264 -crf 23 -c:a copy -stats "$output" \
        && success "Created: $output" || error "Failed"
}

cmd_frame() {
    local input="" output="" at_time="0"
    for arg in "$@"; do [[ "$arg" == "-h" || "$arg" == "--help" ]] && show_frame_help && exit 0; done
    while [[ $# -gt 0 ]]; do
        case "$1" in -v|--verbose) VERBOSE=true; shift;; --at) at_time="$2"; shift 2;; -*) error "Unknown: $1"; exit 1;; *) [[ -z "$input" ]] && input="$1" || output="$1"; shift;; esac
    done
    [[ -z "$input" || -z "$output" ]] && error "Usage: edit frame INPUT OUTPUT [--at TIME]" && exit 1
    [[ ! -f "$input" ]] && error "Not found: $input" && exit 1

    # Get video info for time conversion
    local vid_duration vid_fps
    vid_duration=$(get_duration "$input")
    vid_fps=$(get_video_fps "$input")
    
    # Convert time value to seconds
    local at_sec
    at_sec=$(parse_time_value "$at_time" "$vid_fps" "$vid_duration")

    local loglevel="warning"; [[ "$VERBOSE" == "true" ]] && loglevel="info"
    
    ffmpeg -y -loglevel "$loglevel" -i "$input" -ss "$at_sec" -vframes 1 -stats "$output" && success "Created: $output" || error "Failed"
